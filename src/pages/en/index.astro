---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HomeHero from '../../components/HomeHero.astro';
import USPStrip from '../../components/USPStrip.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import ProcessSteps from '../../components/ProcessSteps.astro';
import StatsCounter from '../../components/StatsCounter.astro';
import ReviewsSection from '../../components/ReviewsSection.astro';
import CTABlock from '../../components/CTABlock.astro';

import foto2 from '../../assets/foto2.jpeg';
import foto1 from '../../assets/foto1.jpeg';
import particulierenSchoonmaak from '../../assets/particulieren_schoonmaak.jpeg';
import recreatieSchoonmaak from '../../assets/recreatieschoonmaak.jpeg';
import opleveringSchoonmaak from '../../assets/opleveringschoonmaak.jpeg';
---

<BaseLayout title="Home" lang="en">
  <main>
    <HomeHero lang="en" />

    <USPStrip lang="en" />

    <section id="diensten" class="section" style="background: #fff;">
      <div class="container">
        <div class="reveal">
          <h2 class="section-heading">Our Services</h2>
          <div class="diensten-grid">
            <ServiceCard
              title="Office Cleaning"
              description="Professional office cleaning for a productive work environment."
              image={foto2}
              href="/en/kantoren-schoonmaak"
            />
            <ServiceCard
              title="Home Cleaning"
              description="Tailored home cleaning for your residence."
              image={particulierenSchoonmaak}
              href="/en/particuliere-schoonmaak"
            />
            <ServiceCard
              title="Restaurant Cleaning"
              description="Hygienic cleaning for hospitality and restaurants."
              image={foto1}
              href="/en/restaurant-schoonmaak"
            />
            <ServiceCard
              title="Holiday Home Cleaning"
              description="Your holiday home always guest-ready."
              image={recreatieSchoonmaak}
              href="/en/schoonmaak-recreatiewoning"
            />
            <ServiceCard
              title="End of Tenancy Cleaning"
              description="Thorough cleaning when handing over properties."
              image={opleveringSchoonmaak}
              href="/en/opleveringsschoonmaak"
            />
          </div>
        </div>
      </div>
    </section>

    <ProcessSteps lang="en" />

    <StatsCounter lang="en" />

    <ReviewsSection lang="en" />

    <CTABlock
      heading="Ready for a fresh start?"
      subtext="Request a free quote"
    />
  </main>
</BaseLayout>

<style>
  .diensten-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 24px;
  }

  /* Each card spans 2 of 6 columns = 3 cards per row */
  .diensten-grid :global(.service-card) {
    grid-column: span 2;
  }

  /* Bottom row: 2 cards each span 3 columns, filling the full width */
  .diensten-grid :global(.service-card:nth-child(4)) {
    grid-column: 1 / span 3;
  }

  .diensten-grid :global(.service-card:nth-child(5)) {
    grid-column: 4 / span 3;
  }

  @media (max-width: 1024px) {
    .diensten-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .diensten-grid :global(.service-card) {
      grid-column: span 1;
    }

    /* Last card spans full width on tablet */
    .diensten-grid :global(.service-card:nth-child(4)) {
      grid-column: span 1;
    }

    .diensten-grid :global(.service-card:nth-child(5)) {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 768px) {
    .diensten-grid {
      grid-template-columns: 1fr;
    }

    .diensten-grid :global(.service-card) {
      grid-column: span 1;
    }

    .diensten-grid :global(.service-card:nth-child(4)),
    .diensten-grid :global(.service-card:nth-child(5)) {
      grid-column: span 1;
    }
  }
</style>
