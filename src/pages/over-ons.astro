---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroBanner from '../components/HeroBanner.astro';
import CTABlock from '../components/CTABlock.astro';
import { Image } from 'astro:assets';

import foto4 from '../assets/foto4.png';
import foto5 from '../assets/foto5.png';
import foto7 from '../assets/foto7.png';
import foto16 from '../assets/foto16.jpeg';
import foto17 from '../assets/foto17.jpeg';
import foto18 from '../assets/foto18.jpeg';
import foto19 from '../assets/foto19.jpeg';
import foto22 from '../assets/foto22.webp';
---

<BaseLayout
  title="Over Ons"
  description="Leer meer over Blink Schoonmaak 010, een jong familiebedrijf met passie voor schoonmaken in Rotterdam en omgeving."
>
  <main>
    <!-- 1. Hero Banner -->
    <HeroBanner
      title="Over Ons"
      subtitle="Maak kennis met het team achter Blink Schoonmaak 010. Persoonlijk, betrouwbaar en altijd in de buurt."
      image={foto4}
      breadcrumbs={[{ label: 'Home', href: '/' }]}
    />

    <!-- 2. Intro Section -->
    <section class="section intro-section">
      <div class="container">
        <div class="intro-grid">
          <div class="intro-text reveal">
            <h2 class="intro-heading">Wie zijn wij?</h2>
            <p>
              Blink Schoonmaak 010 is een jong en ambitieus familiebedrijf uit Rotterdam.
              Met korte communicatielijnen en een persoonlijke aanpak staan wij garant voor
              betrouwbare, kwalitatieve schoonmaakdiensten in de regio.
            </p>
            <p>
              Opgericht vanuit een passie voor netheid en klanttevredenheid, zijn wij
              uitgegroeid tot een vertrouwde partner voor zowel particulieren als bedrijven.
            </p>
          </div>
          <div class="intro-image reveal-right">
            <Image
              src={foto22}
              alt="Eigenaar van Blink Schoonmaak 010 in Blink hoodie"
              width={700}
              height={500}
              format="webp"
              quality={80}
              class="content-foto"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- 3. Video Section -->
    <section class="section video-section">
      <div class="container">
        <div class="reveal">
          <h2 class="section-heading">Zie ons in actie</h2>
        </div>
        <div class="video-wrapper reveal">
          <video class="about-video" src="/offerte-video.mp4" muted loop playsinline controls aria-label="Blink Schoonmaak 010 in actie"></video>
        </div>
      </div>
    </section>

    <!-- 4. Waarden Section -->
    <section class="section waarden-section">
      <div class="container">
        <div class="reveal">
          <h2 class="section-heading">Onze Waarden</h2>
        </div>
        <div class="waarden-grid reveal">
          <article class="waarde-card reveal-item">
            <div class="waarde-icon" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
              </svg>
            </div>
            <h3>Betrouwbaarheid</h3>
            <p>Afspraak is afspraak. U kunt altijd op ons rekenen.</p>
          </article>

          <article class="waarde-card reveal-item">
            <div class="waarde-icon" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="11" cy="11" r="8"/>
                <line x1="21" y1="21" x2="16.65" y2="16.65"/>
              </svg>
            </div>
            <h3>Kwaliteit</h3>
            <p>Oog voor detail in alles wat we doen.</p>
          </article>

          <article class="waarde-card reveal-item">
            <div class="waarde-icon" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M2 12a10 10 0 1 0 20 0"/>
                <path d="M12 2C6.5 2 2 6.5 2 12"/>
                <path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83"/>
                <circle cx="12" cy="12" r="3"/>
              </svg>
            </div>
            <h3>Duurzaamheid</h3>
            <p>Milieuvriendelijke producten en methoden.</p>
          </article>

          <article class="waarde-card reveal-item">
            <div class="waarde-icon" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                <circle cx="9" cy="7" r="4"/>
                <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
              </svg>
            </div>
            <h3>Persoonlijk</h3>
            <p>Korte lijnen, vast contactpersoon, flexibele service.</p>
          </article>
        </div>
      </div>
    </section>

    <!-- 5. Team Gallery Section -->
    <section class="section gallery-section">
      <div class="container">
        <div class="reveal">
          <h2 class="section-heading">Ons Team in Actie</h2>
        </div>
        <div class="team-gallery reveal">
          <div class="gallery-item reveal-item">
            <Image
              src={foto16}
              alt="Twee teamleden van Blink Schoonmaak klaar voor een klus"
              width={600}
              height={450}
              loading="lazy"
              format="webp"
              quality={80}
              class="gallery-foto"
            />
          </div>
          <div class="gallery-item reveal-item">
            <Image
              src={foto17}
              alt="Teamlid van Blink Schoonmaak bezig met ramen lappen"
              width={600}
              height={450}
              loading="lazy"
              format="webp"
              quality={80}
              class="gallery-foto"
            />
          </div>
          <div class="gallery-item reveal-item">
            <Image
              src={foto18}
              alt="Blink Schoonmaak teamlid bezig met keukenreiniging"
              width={600}
              height={450}
              loading="lazy"
              format="webp"
              quality={80}
              class="gallery-foto"
            />
          </div>
          <div class="gallery-item reveal-item">
            <Image
              src={foto19}
              alt="Medewerker van Blink Schoonmaak 010 aan het stofzuigen"
              width={600}
              height={450}
              loading="lazy"
              format="webp"
              quality={80}
              class="gallery-foto"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- 6. Team Section -->
    <section class="section team-section">
      <div class="container">
        <div class="team-grid">
          <div class="team-text-col">
            <div class="reveal">
              <h2 class="team-heading">Ons Team</h2>
              <p class="team-intro">
                Ons diverse team &mdash; van jong en energiek tot ervaren vakmensen &mdash;
                deelt één ding: passie voor een schone omgeving. Al onze medewerkers zijn
                100% Nederlandstalig en worden zorgvuldig geselecteerd op vakmanschap en
                betrouwbaarheid.
              </p>
            </div>
            <div class="team-stats reveal">
              <div class="team-stat reveal-item">
                <span class="team-stat-icon" aria-hidden="true">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
                  </svg>
                </span>
                <span class="team-stat-label">100% Nederlandstalig team</span>
              </div>
              <div class="team-stat reveal-item">
                <span class="team-stat-icon" aria-hidden="true">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="20 6 9 17 4 12"/>
                  </svg>
                </span>
                <span class="team-stat-label">Zorgvuldig geselecteerd</span>
              </div>
              <div class="team-stat reveal-item">
                <span class="team-stat-icon" aria-hidden="true">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/>
                    <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
                  </svg>
                </span>
                <span class="team-stat-label">Doorlopend opgeleid</span>
              </div>
            </div>
          </div>
          <div class="team-image-col reveal-right">
            <div class="team-photos-grid">
              <img src="/team-1.jpg" alt="Teamlid Blink Schoonmaak 010" class="team-photo" loading="lazy" />
              <img src="/team-2.jpg" alt="Teamlid Blink Schoonmaak 010" class="team-photo" loading="lazy" />
              <img src="/team-3.png" alt="Teamlid Blink Schoonmaak 010" class="team-photo" loading="lazy" />
              <img src="/team-4.png" alt="Teamlid Blink Schoonmaak 010" class="team-photo" loading="lazy" />
              <img src="/team-5.jpg" alt="Teamlid Blink Schoonmaak 010" class="team-photo team-photo--wide" loading="lazy" />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- 7. Werkgebied Section -->
    <section class="section werkgebied-section">
      <div class="container">
        <div class="reveal">
          <h2 class="section-heading">Ons Werkgebied</h2>
          <p class="werkgebied-intro">
            Wij zijn actief in Rotterdam en omgeving, waaronder:
          </p>
        </div>
        <ul class="steden-grid reveal" role="list">
          <li class="stad-item reveal-item">Rotterdam</li>
          <li class="stad-item reveal-item">Den Haag</li>
          <li class="stad-item reveal-item">Rijswijk</li>
          <li class="stad-item reveal-item">Zoetermeer</li>
          <li class="stad-item reveal-item">Delft</li>
          <li class="stad-item reveal-item">Capelle aan den IJssel</li>
          <li class="stad-item reveal-item">Barendrecht</li>
          <li class="stad-item reveal-item">Schiedam</li>
          <li class="stad-item reveal-item">Vlaardingen</li>
        </ul>
      </div>
    </section>

    <!-- 8. CTA Block -->
    <CTABlock
      heading="Samenwerken?"
      subtext="Neem contact op voor een vrijblijvend kennismakingsgesprek"
    />
  </main>
</BaseLayout>

<style>
  /* ── 2. Intro ──────────────────────────────────────────────── */
  .intro-section {
    background: var(--color-white);
  }

  .intro-grid {
    display: grid;
    grid-template-columns: 55% 45%;
    gap: 64px;
    align-items: center;
  }

  .intro-text {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .intro-heading {
    text-align: left;
    margin-bottom: 8px;
    color: var(--color-gray-900);
  }

  .intro-text p {
    font-size: 1.075rem;
    line-height: 1.8;
    color: var(--color-gray-800);
  }

  /* ── 3. Video ────────────────────────────────────────────────── */
  .video-section {
    background: var(--color-gray-50);
  }

  .video-wrapper {
    max-width: 720px;
    margin: 0 auto;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.12);
  }

  .about-video {
    width: 100%;
    display: block;
  }

  /* ── 4. Waarden ────────────────────────────────────────────── */
  .waarden-section {
    background: var(--color-gray-50);
  }

  .waarden-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 28px;
  }

  .waarde-card {
    background: var(--color-white);
    border: 1px solid var(--color-gray-100);
    border-radius: 16px;
    padding: 32px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    transition: box-shadow var(--transition-medium), transform var(--transition-medium);
  }

  .waarde-card:hover {
    box-shadow: 0 8px 32px rgba(0, 133, 154, 0.12);
    transform: translateY(-4px);
  }

  .waarde-icon {
    width: 52px;
    height: 52px;
    background: rgba(0, 133, 154, 0.1);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .waarde-icon svg {
    width: 26px;
    height: 26px;
    color: var(--color-primary);
  }

  .waarde-card h3 {
    font-size: 1.2rem;
    font-weight: var(--font-weight-bold);
    color: var(--color-gray-900);
  }

  .waarde-card p {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-gray-800);
    margin: 0;
  }

  /* ── 6. Team ────────────────────────────────────────────────── */
  .team-section {
    background: var(--color-white);
  }

  .team-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: start;
  }

  .team-photos-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    width: 100%;
  }

  .team-photo {
    width: 100%;
    height: 200px;
    object-fit: cover;
    border-radius: 12px;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.10);
    transition: transform var(--transition-medium), box-shadow var(--transition-medium);
  }

  .team-photo:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 28px rgba(0, 133, 154, 0.14);
  }

  .team-photo--wide {
    grid-column: 1 / -1;
    height: 220px;
  }

  .team-text-col {
    display: flex;
    flex-direction: column;
    gap: 36px;
  }

  .team-heading {
    text-align: left;
    margin-bottom: 16px;
    color: var(--color-gray-900);
  }

  .team-intro {
    font-size: 1.075rem;
    line-height: 1.8;
    color: var(--color-gray-800);
  }

  .team-stats {
    display: flex;
    flex-direction: column;
    gap: 16px;
    padding: 28px;
    background: var(--color-gray-50);
    border-radius: 16px;
    border-left: 4px solid var(--color-primary);
  }

  .team-stat {
    display: flex;
    align-items: center;
    gap: 14px;
    font-size: 1rem;
    font-weight: var(--font-weight-semibold);
    color: var(--color-gray-800);
  }

  .team-stat-icon {
    width: 36px;
    height: 36px;
    background: var(--color-primary);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .team-stat-icon svg {
    width: 18px;
    height: 18px;
    color: var(--color-white);
  }

  /* ── 7. Werkgebied ──────────────────────────────────────────── */
  .werkgebied-section {
    background: var(--color-gray-50);
    position: relative;
    overflow: hidden;
  }

  .werkgebied-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 80% at 95% 50%, rgba(0, 133, 154, 0.06) 0%, transparent 70%),
      radial-gradient(ellipse 40% 60% at 5% 50%, rgba(94, 196, 212, 0.06) 0%, transparent 70%);
    pointer-events: none;
  }

  .werkgebied-intro {
    text-align: center;
    font-size: 1.1rem;
    color: var(--color-gray-800);
    margin-top: -24px;
    margin-bottom: 40px;
  }

  .steden-grid {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    max-width: 720px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .stad-item {
    background: var(--color-white);
    border: 1px solid var(--color-gray-100);
    border-radius: 10px;
    padding: 16px 20px;
    text-align: center;
    font-weight: var(--font-weight-semibold);
    font-size: 0.975rem;
    color: var(--color-gray-900);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
  }

  .stad-item::before {
    content: '';
    width: 8px;
    height: 8px;
    background: var(--color-primary);
    border-radius: 50%;
    flex-shrink: 0;
  }

  .stad-item:hover {
    border-color: var(--color-primary-light);
    box-shadow: 0 4px 16px rgba(0, 133, 154, 0.1);
  }

  /* ── 5. Team Gallery ───────────────────────────────────────── */
  .gallery-section {
    background: var(--color-white);
  }

  .team-gallery {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
    margin-top: 40px;
  }

  .gallery-item {
    overflow: hidden;
    border-radius: 12px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.10);
    transition: transform var(--transition-medium), box-shadow var(--transition-medium);
  }

  .gallery-item:hover {
    transform: translateY(-4px);
    box-shadow: 0 10px 32px rgba(0, 133, 154, 0.14);
  }

  .gallery-foto {
    width: 100%;
    height: 280px;
    object-fit: cover;
    display: block;
    border-radius: 12px;
  }

  @media (max-width: 640px) {
    .team-gallery {
      grid-template-columns: 1fr;
    }

    .gallery-foto {
      height: 240px;
    }
  }

  /* ── Shared: slide-in from right ────────────────────────────── */
  .reveal-right {
    opacity: 0;
    transform: translateX(40px);
    transition: opacity var(--transition-slow), transform var(--transition-slow);
  }

  .reveal-right.visible {
    opacity: 1;
    transform: translateX(0);
  }

  .content-foto {
    width: 100%;
    height: auto;
    border-radius: 16px;
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.12);
    object-fit: cover;
  }

  /* ── Responsive ─────────────────────────────────────────────── */
  @media (max-width: 900px) {
    .intro-grid,
    .team-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .intro-image {
      order: -1;
    }
  }

  @media (max-width: 768px) {
    .waarden-grid {
      grid-template-columns: 1fr;
      gap: 20px;
    }

    .steden-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .team-grid {
      gap: 32px;
    }

    .intro-grid {
      gap: 28px;
    }

    .intro-text p {
      font-size: 1rem;
    }

    .team-intro {
      font-size: 1rem;
    }

    .team-stats {
      padding: 20px;
    }
  }

  @media (max-width: 480px) {
    .steden-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .waarde-card {
      padding: 22px;
    }

    .werkgebied-intro {
      font-size: 1rem;
    }
  }

  @media (max-width: 360px) {
    .steden-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .reveal-right {
      opacity: 1;
      transform: none;
    }
  }
</style>

<script>
  const revealRightObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          revealRightObserver.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.12 }
  );

  document.querySelectorAll('.reveal-right').forEach((el) => revealRightObserver.observe(el));
</script>
