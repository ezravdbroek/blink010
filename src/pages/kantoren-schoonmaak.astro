---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroBanner from '../components/HeroBanner.astro';
import CTABlock from '../components/CTABlock.astro';
import { Image } from 'astro:assets';
import heroImg from '../assets/foto2.jpeg';
import galleryImg1 from '../assets/foto4.png';
import galleryImg2 from '../assets/foto5.png';
import teamPhoto21 from '../assets/foto21.jpeg';
---

<BaseLayout
  title="Kantoren Schoonmaak"
  description="Professionele kantoorschoonmaak in Rotterdam. Dagelijks, wekelijks of maandelijks — op maat voor uw bedrijf."
>
  <HeroBanner
    title="Kantoren Schoonmaak"
    image={heroImg}
    breadcrumbs={[{ label: 'Home', href: '/' }]}
  />

  <!-- Intro Section -->
  <section class="section intro-section">
    <div class="container">
      <div class="intro-grid reveal">
        <div class="intro-text">
          <p class="intro-label">Professionele kantoorschoonmaak</p>
          <h2>Een schone werkplek voor uw team</h2>
          <p class="intro-paragraph">
            Een schone werkomgeving is essentieel voor productiviteit en welzijn van uw medewerkers.
            Blink Schoonmaak 010 biedt professionele kantoorschoonmaak in Rotterdam, afgestemd op
            uw wensen en planning.
          </p>
          <a href="/offerte-aanvragen" class="btn btn-primary">
            Meer weten? Neem contact op
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
        <div class="intro-image-wrap">
          <Image src={galleryImg1} alt="Schone kantoorruimte Rotterdam" class="intro-image" />
        </div>
      </div>
    </div>
  </section>

  <!-- USP Section -->
  <section class="section usp-section">
    <div class="container">
      <div class="section-heading reveal">
        <h2>Waarom kiezen voor onze kantoorschoonmaak?</h2>
        <p class="section-sub">Kwaliteit en betrouwbaarheid staan bij ons centraal — elke dag opnieuw.</p>
      </div>
      <div class="usp-grid reveal">
        <div class="usp-card reveal-item">
          <div class="usp-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          </div>
          <h3>Dagelijkse reiniging</h3>
          <p>Uw kantoor is elke ochtend spic en span. Wij zorgen voor een frisse start van uw werkdag, elke dag van de week.</p>
        </div>
        <div class="usp-card reveal-item">
          <div class="usp-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          </div>
          <h3>Flexibel inplanbaar</h3>
          <p>Vroeg in de ochtend, laat in de avond of in het weekend — wij plannen de schoonmaak op uw agenda in, niet omgekeerd.</p>
        </div>
        <div class="usp-card reveal-item">
          <div class="usp-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <h3>Duurzame middelen</h3>
          <p>Wij werken uitsluitend met milieuvriendelijke schoonmaakmiddelen die veilig zijn voor mens, dier en het milieu.</p>
        </div>
        <div class="usp-card reveal-item">
          <div class="usp-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          </div>
          <h3>Gecertificeerd personeel</h3>
          <p>Al onze medewerkers zijn gediplomeerd, gescreend en continu bijgeschoold. U kunt ons volledig vertrouwen.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Photo Gallery -->
  <section class="section gallery-section">
    <div class="container">
      <div class="gallery-grid reveal">
        <div class="gallery-main">
          <Image src={galleryImg1} alt="Professionele kantoorschoonmaak" class="gallery-img" />
        </div>
        <div class="gallery-side">
          <Image src={galleryImg2} alt="Schone werkplekken" class="gallery-img" />
          <Image src={teamPhoto21} alt="Blink Schoonmaak 010 bedrijfswagen Rotterdam" class="gallery-img" />
          <div class="gallery-badge">
            <span class="badge-number">10+</span>
            <span class="badge-text">jaar ervaring</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Process Timeline -->
  <section class="section timeline-section">
    <div class="container">
      <div class="section-heading reveal">
        <h2>Hoe werkt het?</h2>
        <p class="section-sub">Van eerste contact tot een vlekkeloos schoon kantoor — in vier eenvoudige stappen.</p>
      </div>
      <div class="timeline">
        <div class="timeline-item timeline-left">
          <div class="timeline-content">
            <h3>Offerte aanvragen</h3>
            <p>Vul het formulier in of neem contact op. Wij reageren binnen één werkdag.</p>
          </div>
          <div class="timeline-circle">1</div>
          <div class="timeline-spacer"></div>
        </div>
        <div class="timeline-item timeline-right">
          <div class="timeline-spacer"></div>
          <div class="timeline-circle">2</div>
          <div class="timeline-content">
            <h3>Vrijblijvend gesprek</h3>
            <p>We bespreken uw wensen en situatie. Geen verplichtingen, wel concrete oplossingen.</p>
          </div>
        </div>
        <div class="timeline-item timeline-left">
          <div class="timeline-content">
            <h3>Planning</h3>
            <p>We stellen een passend schoonmaakplan op dat naadloos aansluit bij uw bedrijfsvoering.</p>
          </div>
          <div class="timeline-circle">3</div>
          <div class="timeline-spacer"></div>
        </div>
        <div class="timeline-item timeline-right">
          <div class="timeline-spacer"></div>
          <div class="timeline-circle">4</div>
          <div class="timeline-content">
            <h3>Schoonmaak</h3>
            <p>Onze vakmensen gaan aan de slag! U hoeft er niets voor te doen — wij regelen alles.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CTABlock
    heading="Interesse in kantoorschoonmaak? Vraag een offerte aan."
    subtext="Neem vandaag nog contact op — wij reageren binnen één werkdag."
  />
</BaseLayout>

<style>
  /* ── Intro ── */
  .intro-section {
    background: var(--color-white);
  }

  .intro-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
  }

  .intro-label {
    display: inline-block;
    font-size: 0.85rem;
    font-weight: var(--font-weight-bold);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: 12px;
  }

  .intro-text h2 {
    margin-bottom: 20px;
    color: var(--color-gray-900);
  }

  .intro-paragraph {
    font-size: 1.1rem;
    line-height: 1.8;
    color: var(--color-gray-800);
    margin-bottom: 32px;
  }

  .intro-image-wrap {
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.12);
  }

  .intro-image {
    width: 100%;
    height: 400px;
    object-fit: cover;
    display: block;
  }

  /* ── USPs ── */
  .usp-section {
    background: var(--color-gray-50);
  }

  .section-sub {
    font-size: 1.05rem;
    color: var(--color-gray-400);
    margin-top: 12px;
    max-width: 560px;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.6;
  }

  .usp-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    margin-top: 8px;
  }

  .usp-card {
    background: var(--color-white);
    border: 1px solid var(--color-gray-100);
    border-radius: 16px;
    padding: 32px;
    transition: box-shadow 0.3s ease, transform 0.3s ease;
  }

  .usp-card:hover {
    box-shadow: 0 12px 40px rgba(0, 133, 154, 0.1);
    transform: translateY(-4px);
  }

  .usp-icon {
    width: 56px;
    height: 56px;
    background: rgba(0, 133, 154, 0.08);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-primary);
    margin-bottom: 20px;
  }

  .usp-card h3 {
    font-size: 1.1rem;
    font-weight: var(--font-weight-bold);
    color: var(--color-gray-900);
    margin-bottom: 10px;
    line-height: 1.3;
  }

  .usp-card p {
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--color-gray-800);
  }

  /* ── Gallery ── */
  .gallery-section {
    background: var(--color-white);
    padding-top: 0;
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: 3fr 2fr;
    gap: 20px;
    align-items: stretch;
  }

  .gallery-main,
  .gallery-side {
    border-radius: 16px;
    overflow: hidden;
    position: relative;
  }

  .gallery-side {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .gallery-img {
    width: 100%;
    height: 100%;
    min-height: 260px;
    object-fit: cover;
    display: block;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
    border-radius: 16px;
  }

  .gallery-badge {
    background: var(--color-primary);
    border-radius: 16px;
    padding: 28px 24px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    flex: 1;
    min-height: 120px;
  }

  .badge-number {
    font-size: 2.5rem;
    font-weight: var(--font-weight-extrabold);
    color: var(--color-white);
    line-height: 1;
  }

  .badge-text {
    font-size: 0.95rem;
    color: rgba(255, 255, 255, 0.85);
    margin-top: 6px;
    font-weight: var(--font-weight-semibold);
  }

  /* ── Timeline ── */
  .timeline-section {
    background: var(--color-gray-50);
  }

  .timeline {
    position: relative;
    max-width: 860px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 50%;
    top: 28px;
    bottom: 28px;
    width: 2px;
    background: var(--color-gray-100);
    transform: translateX(-50%);
  }

  .timeline-item {
    display: grid;
    grid-template-columns: 1fr 56px 1fr;
    align-items: center;
    gap: 0;
    padding: 20px 0;
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.5s ease-out, transform 0.5s ease-out;
  }

  .timeline-item.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .timeline-circle {
    width: 56px;
    height: 56px;
    background: var(--color-primary);
    color: var(--color-white);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.2rem;
    font-weight: var(--font-weight-extrabold);
    flex-shrink: 0;
    position: relative;
    z-index: 2;
    box-shadow: 0 4px 16px rgba(0, 133, 154, 0.35);
  }

  .timeline-content {
    background: var(--color-white);
    border: 1px solid var(--color-gray-100);
    border-radius: 14px;
    padding: 24px 28px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
  }

  .timeline-content h3 {
    font-size: 1.05rem;
    font-weight: var(--font-weight-bold);
    color: var(--color-gray-900);
    margin-bottom: 8px;
    line-height: 1.3;
  }

  .timeline-content p {
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--color-gray-800);
    margin: 0;
  }

  .timeline-left .timeline-content {
    text-align: right;
  }

  .timeline-right .timeline-content {
    text-align: left;
  }

  .timeline-spacer {
    /* fills the empty opposite column */
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .intro-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .intro-image {
      height: 300px;
    }

    .usp-grid {
      grid-template-columns: 1fr;
    }

    .gallery-grid {
      grid-template-columns: 1fr;
    }

    .gallery-img {
      height: 260px;
    }

    .gallery-badge {
      min-height: 80px;
      padding: 20px;
    }

    .timeline::before {
      left: 28px;
    }

    .timeline-item {
      grid-template-columns: 56px 1fr;
      grid-template-rows: auto;
    }

    .timeline-left,
    .timeline-right {
      display: flex;
      flex-direction: row;
      align-items: flex-start;
      gap: 20px;
    }

    .timeline-spacer {
      display: none;
    }

    .timeline-left .timeline-content,
    .timeline-right .timeline-content {
      text-align: left;
    }

    .timeline-left .timeline-circle {
      order: -1;
    }
  }

  @media (max-width: 600px) {
    .usp-card {
      padding: 22px;
    }

    .timeline-content {
      padding: 16px 18px;
    }

    .intro-paragraph {
      font-size: 1rem;
    }

    .timeline-left,
    .timeline-right {
      gap: 14px;
    }

    .timeline-circle {
      width: 44px;
      height: 44px;
      font-size: 1rem;
    }
  }
</style>

<script>
  // Timeline sequential reveal
  const timelineItems = document.querySelectorAll('.timeline-item');
  if (timelineItems.length) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const index = Array.from(timelineItems).indexOf(entry.target as HTMLElement);
            setTimeout(() => {
              (entry.target as HTMLElement).classList.add('visible');
            }, index * 150);
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.15 }
    );
    timelineItems.forEach((item) => observer.observe(item));
  }
</script>
