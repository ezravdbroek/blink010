---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroBanner from '../components/HeroBanner.astro';
import ContactForm from '../components/ContactForm.astro';
---

<BaseLayout
  title="Contact"
  description="Neem contact op met Blink Schoonmaak 010 voor een vrijblijvende offerte of meer informatie over onze schoonmaakdiensten in Rotterdam."
>
  <main>
    <HeroBanner
      title="Contact"
      subtitle="Neem gerust contact met ons op. Wij reageren binnen één werkdag op uw bericht."
      breadcrumbs={[{ label: 'Home', href: '/' }]}
    />

    <section class="section contact-section">
      <div class="container">
        <div class="contact-grid">

          <!-- Left column: contact form -->
          <div class="col-form reveal reveal-left">
            <h2 class="col-heading">Stuur ons een bericht</h2>
            <ContactForm />
          </div>

          <!-- Right column: details + map + whatsapp -->
          <div class="col-details reveal reveal-right">

            <!-- Contact details card -->
            <div class="details-card">
              <h2 class="col-heading">Contactgegevens</h2>

              <ul class="details-list">
                <li class="detail-item">
                  <!-- Location pin icon -->
                  <svg class="detail-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                    <circle cx="12" cy="10" r="3"/>
                  </svg>
                  <span>Theodoor Colenbranderhof 5, 3059 LS Rotterdam</span>
                </li>

                <li class="detail-item">
                  <!-- Phone icon -->
                  <svg class="detail-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.6a16 16 0 0 0 6.29 6.29l.96-.96a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
                  </svg>
                  <a href="tel:0611125603" class="detail-link">0611125603</a>
                </li>

                <li class="detail-item">
                  <!-- Email icon -->
                  <svg class="detail-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                    <polyline points="22,6 12,13 2,6"/>
                  </svg>
                  <a href="mailto:info@blinkschoonmaak.nl" class="detail-link">info@blinkschoonmaak.nl</a>
                </li>

                <li class="detail-item">
                  <!-- KVK / building icon -->
                  <svg class="detail-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <rect x="2" y="7" width="20" height="14" rx="2"/>
                    <path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/>
                  </svg>
                  <span>KVK: 94000395</span>
                </li>
              </ul>
            </div>

            <!-- Google Maps embed -->
            <div class="map-wrapper">
              <iframe
                src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2461.5!2d4.4777!3d51.9225!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2sTheodoor+Colenbranderhof+5+Rotterdam!5e0!3m2!1sen!2snl"
                width="100%"
                height="250"
                style="border: none; border-radius: 12px; display: block;"
                loading="lazy"
                title="Locatie Blink Schoonmaak 010"
                referrerpolicy="no-referrer-when-downgrade"
                allowfullscreen
              ></iframe>
            </div>

            <!-- WhatsApp section -->
            <div class="whatsapp-block">
              <h3 class="whatsapp-heading">Direct chatten?</h3>
              <p class="whatsapp-text">Stuur ons een bericht op WhatsApp</p>
              <a
                href="https://wa.me/31611125603"
                class="btn btn-whatsapp"
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Open WhatsApp chat met Blink Schoonmaak 010"
              >
                <!-- WhatsApp SVG icon -->
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" class="wa-icon">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/>
                </svg>
                WhatsApp
              </a>
            </div>

          </div>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .contact-section {
    background: var(--color-gray-50);
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 55% 1fr;
    gap: 40px;
    align-items: start;
  }

  /* Slide from left override for the form column */
  .reveal-left {
    transform: translateX(-40px);
  }

  .reveal-left.visible {
    transform: translateX(0);
  }

  /* Slide from right override for the details column */
  .reveal-right {
    transform: translateX(40px);
  }

  .reveal-right.visible {
    transform: translateX(0);
  }

  /* Column headings */
  .col-heading {
    font-size: clamp(1.3rem, 3vw, 1.75rem);
    font-weight: var(--font-weight-extrabold);
    color: var(--color-gray-800);
    margin-bottom: 28px;
  }

  /* ---- Details card ---- */
  .details-card {
    background: var(--color-white);
    border-radius: 16px;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.08);
    padding: 32px;
    margin-bottom: 24px;
  }

  .details-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 18px;
  }

  .detail-item {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    font-size: 0.97rem;
    color: var(--color-gray-800);
    line-height: 1.5;
  }

  .detail-icon {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
    color: var(--color-primary);
    margin-top: 2px;
  }

  .detail-link {
    color: var(--color-primary);
    font-weight: var(--font-weight-semibold);
    transition: color var(--transition-fast);
  }

  .detail-link:hover {
    color: var(--color-primary-dark);
    text-decoration: underline;
  }

  /* ---- Map ---- */
  .map-wrapper {
    margin-bottom: 24px;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
  }

  /* ---- WhatsApp block ---- */
  .whatsapp-block {
    background: var(--color-white);
    border-radius: 16px;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.08);
    padding: 28px 32px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .whatsapp-heading {
    font-size: 1.15rem;
    font-weight: var(--font-weight-bold);
    color: var(--color-gray-800);
    margin: 0;
  }

  .whatsapp-text {
    font-size: 0.95rem;
    color: var(--color-gray-400);
    margin: 0;
  }

  .btn-whatsapp {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 13px 28px;
    background: #25d366;
    color: #fff;
    border-radius: 10px;
    font-weight: var(--font-weight-bold);
    font-size: 1rem;
    transition: transform var(--transition-fast), box-shadow var(--transition-fast), background var(--transition-fast);
    box-shadow: 0 4px 16px rgba(37, 211, 102, 0.3);
    align-self: flex-start;
    margin-top: 4px;
  }

  .btn-whatsapp:hover {
    background: #1ebe5d;
    transform: translateY(-2px);
    box-shadow: 0 6px 24px rgba(37, 211, 102, 0.45);
  }

  .wa-icon {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }

  /* ---- Responsive ---- */
  @media (max-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    /* On mobile the form comes first (DOM order), details second — matches requirement */

    .reveal-left,
    .reveal-right {
      transform: translateY(30px);
    }

    .reveal-left.visible,
    .reveal-right.visible {
      transform: translateY(0);
    }

    .details-card,
    .whatsapp-block {
      padding: 24px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .reveal-left,
    .reveal-right {
      transform: none;
      opacity: 1;
    }
  }
</style>

<script>
  // Observe the directional reveal columns separately from the global BaseLayout observer
  // (BaseLayout only handles translateY; we override with translateX here)
  const dirObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          dirObserver.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1 }
  );

  document.querySelectorAll('.reveal-left, .reveal-right').forEach((el) => {
    dirObserver.observe(el);
  });
</script>
