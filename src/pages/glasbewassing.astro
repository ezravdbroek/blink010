---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroBanner from '../components/HeroBanner.astro';
import CTABlock from '../components/CTABlock.astro';
import { Image } from 'astro:assets';
import heroImg from '../assets/foto14.jpg';
import autoZijkant2 from '../assets/auto-zijkant2.jpeg';
import foto20 from '../assets/foto20.jpeg';
---

<BaseLayout
  title="Glasbewassing"
  description="Professionele glasbewassing in Rotterdam. Streeploos schone ramen voor woningen, kantoren en bedrijfspanden."
>
  <HeroBanner
    title="Glasbewassing"
    subtitle="Streeploos schone ramen voor woningen en bedrijfspanden. Transparantie tot in de puntjes."
    ctaText="Vraag een offerte aan"
    image={heroImg}
    breadcrumbs={[{ label: 'Home', href: '/' }]}
  />

  <!-- Intro Section -->
  <section class="section intro-section">
    <div class="container">
      <div class="intro-grid reveal">
        <div class="intro-text">
          <p class="intro-label">Glasbewassing</p>
          <h2>Streeploos schoon — van binnen én buiten</h2>
          <p class="intro-paragraph">
            Ramen zijn het visitekaartje van uw pand, maar worden vaak over het hoofd gezien. Een professionele glasbewassing zorgt niet alleen voor een frisse uitstraling, maar laat ook meer licht binnen en verlengt de levensduur van uw kozijnen. Wij bieden vakkundige glasbewassing voor particulieren, bedrijven, VvE's en winkelpanden. Veilig, duurzaam en met een streeploos resultaat — van binnenuit of met hoogwerker voor de lastig bereikbare plekken.
          </p>
          <a href="/offerte-aanvragen" class="btn btn-primary">
            Offerte aanvragen
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
        <div class="intro-image-wrap">
          <Image src={autoZijkant2} alt="Professionele glasbewassing" class="intro-image" />
        </div>
      </div>
    </div>
  </section>

  <!-- USP Section -->
  <section class="section usp-section">
    <div class="container">
      <div class="section-heading reveal">
        <h2>Waarom kiezen voor onze glasbewassing?</h2>
        <p class="section-sub">Wij tillen glasbewassing naar een hoger niveau.</p>
      </div>
      <div class="usp-grid reveal">
        <div class="usp-card reveal-item">
          <div class="usp-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          </div>
          <h3>Streeploos resultaat</h3>
          <p>Wij gebruiken professionele materialen en technieken voor een kraakhelder, streeploos resultaat — elke keer weer.</p>
        </div>
        <div class="usp-card reveal-item">
          <div class="usp-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <h3>Veiligheid voorop</h3>
          <p>Voor hooggelegen ramen en moeilijk bereikbare plekken werken wij met gecertificeerde hoogwerkers en veiligheidsmaterialen.</p>
        </div>
        <div class="usp-card reveal-item">
          <div class="usp-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          </div>
          <h3>Zakelijk & particulier</h3>
          <p>Van eengezinswoningen tot kantoorpanden, winkelpanden en VvE's — wij hebben voor elke opdracht de juiste aanpak.</p>
        </div>
        <div class="usp-card reveal-item">
          <div class="usp-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 2h18v5H3zM3 9h18v5H3zM3 16h18v5H3z"/></svg>
          </div>
          <h3>Kozijnen & kozijnonderhoud</h3>
          <p>Tijdens de glasbewassing inspecteren en reinigen wij direct de kozijnen. Zo blijven ze langer mooi en in goede staat.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Photo Gallery -->
  <section class="section gallery-section">
    <div class="container">
      <div class="gallery-grid reveal">
        <div class="gallery-main">
          <Image src={foto20} alt="Professionele glasbewassing in de praktijk" class="gallery-img" />
          <div class="gallery-overlay">
            <span>Streeploos schoon, elke keer</span>
          </div>
        </div>
        <div class="gallery-stats">
          <div class="stat-card">
            <span class="stat-number">500+</span>
            <span class="stat-label">Panden gewassen</span>
          </div>
          <div class="stat-card stat-card-alt">
            <span class="stat-number">100%</span>
            <span class="stat-label">Tevredenheidsgarantie</span>
          </div>
          <div class="stat-card">
            <span class="stat-number">5&#9733;</span>
            <span class="stat-label">Gemiddelde beoordeling</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Process Timeline -->
  <section class="section timeline-section">
    <div class="container">
      <div class="section-heading reveal">
        <h2>Hoe werkt het?</h2>
        <p class="section-sub">Van offerte tot sprankelend schoon glas — eenvoudig en snel geregeld.</p>
      </div>
      <div class="timeline">
        <div class="timeline-item timeline-left">
          <div class="timeline-content">
            <h3>Offerte aanvragen</h3>
            <p>Vul het formulier in of bel. Binnen één werkdag ontvangt u een offerte op maat.</p>
          </div>
          <div class="timeline-circle">1</div>
          <div class="timeline-spacer"></div>
        </div>
        <div class="timeline-item timeline-right">
          <div class="timeline-spacer"></div>
          <div class="timeline-circle">2</div>
          <div class="timeline-content">
            <h3>Opname</h3>
            <p>We beoordelen de locatie en bepalen de juiste techniek en veiligheidsmaatregelen.</p>
          </div>
        </div>
        <div class="timeline-item timeline-left">
          <div class="timeline-content">
            <h3>Inplannen</h3>
            <p>Wij plannen de glasbewassing op een voor u geschikt moment, zonder overlast.</p>
          </div>
          <div class="timeline-circle">3</div>
          <div class="timeline-spacer"></div>
        </div>
        <div class="timeline-item timeline-right">
          <div class="timeline-spacer"></div>
          <div class="timeline-circle">4</div>
          <div class="timeline-content">
            <h3>Glasbewassing</h3>
            <p>Onze specialisten zorgen voor streeploos schone ramen — van binnenuit of met hoogwerker.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CTABlock
    heading="Wilt u streeploos schone ramen? Vraag een offerte aan."
    subtext="Neem vandaag nog contact op — wij reageren binnen één werkdag."
  />
</BaseLayout>

<style>
  .intro-section {
    background: var(--color-white);
  }

  .intro-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
  }

  .intro-label {
    display: inline-block;
    font-size: 0.85rem;
    font-weight: var(--font-weight-bold);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: 12px;
  }

  .intro-text h2 {
    margin-bottom: 20px;
    color: var(--color-gray-900);
  }

  .intro-paragraph {
    font-size: 1.1rem;
    line-height: 1.8;
    color: var(--color-gray-800);
    margin-bottom: 32px;
  }

  .intro-image-wrap {
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.12);
  }

  .intro-image {
    width: 100%;
    height: 400px;
    object-fit: cover;
    display: block;
  }

  .usp-section {
    background: var(--color-gray-50);
  }

  .section-sub {
    font-size: 1.05rem;
    color: var(--color-gray-400);
    margin-top: 12px;
    max-width: 560px;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.6;
  }

  .usp-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    margin-top: 8px;
  }

  .usp-card {
    background: var(--color-white);
    border: 1px solid var(--color-gray-100);
    border-radius: 16px;
    padding: 32px;
    transition: box-shadow 0.3s ease, transform 0.3s ease;
  }

  .usp-card:hover {
    box-shadow: 0 12px 40px rgba(0, 133, 154, 0.1);
    transform: translateY(-4px);
  }

  .usp-icon {
    width: 56px;
    height: 56px;
    background: rgba(0, 133, 154, 0.08);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-primary);
    margin-bottom: 20px;
  }

  .usp-card h3 {
    font-size: 1.1rem;
    font-weight: var(--font-weight-bold);
    color: var(--color-gray-900);
    margin-bottom: 10px;
    line-height: 1.3;
  }

  .usp-card p {
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--color-gray-800);
  }

  .gallery-section {
    background: var(--color-white);
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: 3fr 2fr;
    gap: 20px;
    align-items: stretch;
  }

  .gallery-main {
    border-radius: 16px;
    overflow: hidden;
    position: relative;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
  }

  .gallery-img {
    width: 100%;
    height: 420px;
    object-fit: cover;
    display: block;
  }

  .gallery-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.6) 0%, transparent 100%);
    padding: 28px 24px 20px;
    color: var(--color-white);
    font-weight: var(--font-weight-semibold);
    font-size: 1rem;
  }

  .gallery-stats {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .stat-card {
    background: var(--color-gray-50);
    border: 1px solid var(--color-gray-100);
    border-radius: 16px;
    padding: 28px 24px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    flex: 1;
  }

  .stat-card-alt {
    background: var(--color-primary);
    border-color: var(--color-primary);
  }

  .stat-card-alt .stat-number,
  .stat-card-alt .stat-label {
    color: var(--color-white);
  }

  .stat-number {
    font-size: 2rem;
    font-weight: var(--font-weight-extrabold);
    color: var(--color-primary);
    line-height: 1;
  }

  .stat-label {
    font-size: 0.9rem;
    color: var(--color-gray-400);
    margin-top: 6px;
    font-weight: var(--font-weight-semibold);
  }

  .timeline-section {
    background: var(--color-gray-50);
  }

  .timeline {
    position: relative;
    max-width: 860px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 50%;
    top: 28px;
    bottom: 28px;
    width: 2px;
    background: var(--color-gray-100);
    transform: translateX(-50%);
  }

  .timeline-item {
    display: grid;
    grid-template-columns: 1fr 56px 1fr;
    align-items: center;
    padding: 20px 0;
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.5s ease-out, transform 0.5s ease-out;
  }

  .timeline-item.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .timeline-circle {
    width: 56px;
    height: 56px;
    background: var(--color-primary);
    color: var(--color-white);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.2rem;
    font-weight: var(--font-weight-extrabold);
    flex-shrink: 0;
    position: relative;
    z-index: 2;
    box-shadow: 0 4px 16px rgba(0, 133, 154, 0.35);
  }

  .timeline-content {
    background: var(--color-white);
    border: 1px solid var(--color-gray-100);
    border-radius: 14px;
    padding: 24px 28px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
  }

  .timeline-content h3 {
    font-size: 1.05rem;
    font-weight: var(--font-weight-bold);
    color: var(--color-gray-900);
    margin-bottom: 8px;
    line-height: 1.3;
  }

  .timeline-content p {
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--color-gray-800);
    margin: 0;
  }

  .timeline-left .timeline-content {
    text-align: right;
  }

  .timeline-right .timeline-content {
    text-align: left;
  }

  .timeline-spacer {
  }

  @media (max-width: 900px) {
    .intro-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .intro-image {
      height: 300px;
    }

    .usp-grid {
      grid-template-columns: 1fr;
    }

    .gallery-grid {
      grid-template-columns: 1fr;
    }

    .gallery-img {
      height: 280px;
    }

    .gallery-stats {
      flex-direction: row;
    }

    .stat-card {
      padding: 20px 16px;
    }

    .timeline::before {
      left: 28px;
    }

    .timeline-item {
      display: flex;
      flex-direction: row;
      align-items: flex-start;
      gap: 20px;
    }

    .timeline-spacer {
      display: none;
    }

    .timeline-left .timeline-content,
    .timeline-right .timeline-content {
      text-align: left;
    }

    .timeline-left .timeline-circle {
      order: -1;
    }
  }

  @media (max-width: 600px) {
    .usp-card {
      padding: 24px;
    }

    .gallery-stats {
      flex-direction: column;
    }

    .timeline-content {
      padding: 18px 20px;
    }
  }
</style>

<script>
  const timelineItems = document.querySelectorAll('.timeline-item');
  if (timelineItems.length) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const index = Array.from(timelineItems).indexOf(entry.target as HTMLElement);
            setTimeout(() => {
              (entry.target as HTMLElement).classList.add('visible');
            }, index * 150);
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.15 }
    );
    timelineItems.forEach((item) => observer.observe(item));
  }
</script>
