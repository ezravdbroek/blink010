---
import { Image } from 'astro:assets';
import ikPhoto from '../assets/ik.png';
---

<div class="whatsapp-wrapper">
  <div class="whatsapp-photo">
    <Image src={ikPhoto} alt="Blink Schoonmaak 010" width={40} height={40} format="webp" />
  </div>
  <a
    href="https://wa.me/31611125603"
    target="_blank"
    rel="noopener noreferrer"
    aria-label="Chat met ons op WhatsApp"
    class="whatsapp-btn"
  >
    <svg viewBox="0 0 24 24" fill="white" width="28" height="28" aria-hidden="true">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
    </svg>
    <span class="whatsapp-tooltip" aria-hidden="true">Chat met ons op WhatsApp</span>
  </a>
</div>

<style>
  @keyframes whatsapp-pulse {
    0%   { box-shadow: 0 0 0 0 rgba(37, 211, 102, 0.7), 0 4px 16px rgba(0, 0, 0, 0.3); }
    70%  { box-shadow: 0 0 0 14px rgba(37, 211, 102, 0), 0 4px 16px rgba(0, 0, 0, 0.3); }
    100% { box-shadow: 0 0 0 0 rgba(37, 211, 102, 0), 0 4px 16px rgba(0, 0, 0, 0.3); }
  }

  .whatsapp-wrapper {
    position: fixed;
    bottom: 24px;
    right: 24px;
    z-index: 999;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
  }

  .whatsapp-photo {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    overflow: hidden;
    border: 2px solid white;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
    margin-bottom: -8px; /* overlap with the green button */
    z-index: 1;
  }

  .whatsapp-photo :global(img) {
    width: 100% !important;
    height: 100% !important;
    object-fit: cover !important;
    max-width: none !important;
  }

  .whatsapp-btn {
    display: flex;
    align-items: center;
    justify-content: center;

    width: 56px;
    height: 56px;
    border-radius: 50%;
    background-color: #25D366;

    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.3);
    text-decoration: none;
    color: white;

    /* Run pulse 3 times then stop */
    animation: whatsapp-pulse 1.2s ease-out 3;

    transition: transform 0.2s ease, background-color 0.2s ease;
  }

  .whatsapp-btn:hover {
    transform: scale(1.08);
    background-color: #1ebe5d;
  }

  /* Tooltip */
  .whatsapp-tooltip {
    position: absolute;
    bottom: calc(100% + 10px);
    right: 0;
    white-space: nowrap;

    background-color: #1a1a1a;
    color: #ffffff;
    font-size: 0.8rem;
    font-weight: 500;
    padding: 0.4rem 0.75rem;
    border-radius: 6px;

    pointer-events: none;
    opacity: 0;
    transform: translateY(4px);
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  /* Tooltip arrow */
  .whatsapp-tooltip::after {
    content: '';
    position: absolute;
    top: 100%;
    right: 18px;
    border: 5px solid transparent;
    border-top-color: #1a1a1a;
  }

  .whatsapp-btn:hover .whatsapp-tooltip {
    opacity: 1;
    transform: translateY(0);
  }
</style>
