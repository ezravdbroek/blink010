const totalReviews = reviews.length;
const avgRating = '4.9';
---

<section class="reviews-section section">
  <div class="container">
    <h2 class="section-heading reveal" style="margin-bottom: 12px;">{isEn ? 'What our clients say' : 'Wat onze klanten zeggen'}</h2>

    <div class="reviews-summary reveal">
      <div class="summary-stars" aria-label={`${avgRating} van 5 sterren`}>
        <span class="star">&#9733;</span>
        <span class="star">&#9733;</span>
        <span class="star">&#9733;</span>
        <span class="star">&#9733;</span>
        <span class="star">&#9733;</span>
      </div>
      <p class="summary-text">
        <strong>{avgRating}/5</strong> — {isEn ? 'based on Trustoo and Google Reviews' : 'gebaseerd op Trustoo en Google Reviews'}
      </p>
    </div>

    <div class="slider-wrapper reveal">
      <div class="slider-overflow">
        <div class="slider-track" id="reviews-slider">
          {reviews.map((review) => (
            <div class="slider-card">
              <ReviewCard
                quote={review.quote}
                name={review.name}
                type={review.type}
              />
            </div>
          ))}
        </div>
      </div>

      <button class="slider-btn slider-btn-prev" id="slider-prev" aria-label={isEn ? 'Previous reviews' : 'Vorige reviews'}>
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
      </button>
      <button class="slider-btn slider-btn-next" id="slider-next" aria-label={isEn ? 'Next reviews' : 'Volgende reviews'}>
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
      </button>

      <div class="slider-dots" id="slider-dots" aria-hidden="true"></div>
    </div>
  </div>
</section>

<style>
  .reviews-section {
    background: #ffffff;
  }

  /* Summary */
  .reviews-summary {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    margin-bottom: 28px;
  }

  .summary-stars {
    display: flex;
    gap: 2px;
  }

  .summary-stars .star {
    color: #eab308;
    font-size: 1.4rem;
  }

  .summary-text {
    font-size: 1.05rem;
    color: var(--color-gray-800, #333);
    margin: 0;
  }

  .summary-text strong {
    color: var(--color-gray-900, #111);
  }

  /* Slider */
  .slider-wrapper {
    position: relative;
  }

  .slider-overflow {
    overflow: hidden;
    padding: 12px 0;
    margin: -12px 0;
  }

  .slider-track {
    display: flex;
    gap: 24px;
    align-items: stretch;
    transition: transform 0.7s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .slider-card {
    flex: 0 0 calc((100% - 48px) / 3);
    min-width: 0;
    display: flex;
  }

  .slider-card > :global(article) {
    flex: 1;
  }

  /* Buttons */
  .slider-btn {
    position: absolute;
    top: calc(50% - 20px);
    transform: translateY(-50%);
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: #ffffff;
    border: 1px solid var(--color-gray-100, #e5e7eb);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: var(--color-gray-900, #111);
    transition: background 0.2s, box-shadow 0.2s, color 0.2s;
    z-index: 2;
  }

  .slider-btn:hover {
    background: var(--color-primary, #00859a);
    color: #fff;
    border-color: var(--color-primary, #00859a);
  }

  .slider-btn-prev {
    left: -56px;
  }

  .slider-btn-next {
    right: -56px;
  }

  /* Dots */
  .slider-dots {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-top: 32px;
  }

  .slider-dots .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: #ddd;
    border: none;
    padding: 0;
    cursor: pointer;
    transition: background 0.2s ease, transform 0.2s ease;
  }

  .slider-dots .dot.active {
    background: var(--color-primary, #00859a);
    transform: scale(1.2);
  }

  /* Tablet: 2 cards */
  @media (max-width: 1024px) {
    .slider-card {
      flex: 0 0 calc((100% - 24px) / 2);
    }

    .slider-btn-prev { left: -8px; }
    .slider-btn-next { right: -8px; }
  }

  /* Mobile: 1 card */
  @media (max-width: 640px) {
    .reviews-summary {
      flex-direction: column;
      gap: 8px;
    }

    .slider-track {
      gap: 14px;
    }

    .slider-card {
      flex: 0 0 100%;
    }

    .slider-btn {
      display: none;
    }
  }
</style>

<script>
  function initSlider() {
    const track = document.getElementById('reviews-slider') as HTMLElement;
    const dotsContainer = document.getElementById('slider-dots') as HTMLElement;
    const prevBtn = document.getElementById('slider-prev') as HTMLButtonElement;
    const nextBtn = document.getElementById('slider-next') as HTMLButtonElement;

    if (!track || !dotsContainer || !prevBtn || !nextBtn) return;

    const cards = Array.from(track.children) as HTMLElement[];
    const totalCards = cards.length;
    let currentPage = 0;
    let autoplayTimer: ReturnType<typeof setInterval> | null = null;
    let pauseTimeout: ReturnType<typeof setTimeout> | null = null;

    function getCardsPerPage(): number {
      const w = window.innerWidth;
      if (w <= 640) return 1;
      if (w <= 1024) return 2;
      return 3;
    }

    function getGap(): number {
      return window.innerWidth <= 640 ? 14 : 24;
    }

    function getMaxSlide(): number {
      const perPage = getCardsPerPage();
      return Math.max(0, totalCards - perPage);
    }

    function buildDots() {
      const maxSlide = getMaxSlide();
      dotsContainer.innerHTML = '';
      for (let i = 0; i <= maxSlide; i++) {
        const dot = document.createElement('button');
        dot.className = i === currentPage ? 'dot active' : 'dot';
        dot.setAttribute('data-page', String(i));
        dot.setAttribute('aria-label', `${isEn ? 'Go to review' : 'Ga naar review'} ${i + 1}`);
        dot.addEventListener('click', () => {
          goToPage(i);
          pauseAutoplay();
        });
        dotsContainer.appendChild(dot);
      }
    }

    function updateDots() {
      const dots = dotsContainer.querySelectorAll('.dot');
      dots.forEach((dot, i) => {
        dot.classList.toggle('active', i === currentPage);
      });
    }

    function goToPage(page: number) {
      const maxSlide = getMaxSlide();
      // Loop around
      if (page > maxSlide) page = 0;
      if (page < 0) page = maxSlide;
      currentPage = page;

      const gap = getGap();
      const cardWidth = cards[0].offsetWidth;
      const offset = page * (cardWidth + gap);
      track.style.transform = `translateX(-${offset}px)`;

      updateDots();
    }

    function startAutoplay() {
      stopAutoplay();
      autoplayTimer = setInterval(() => {
        goToPage(currentPage + 1);
      }, 7000);
    }

    function stopAutoplay() {
      if (autoplayTimer) {
        clearInterval(autoplayTimer);
        autoplayTimer = null;
      }
    }

    function pauseAutoplay() {
      stopAutoplay();
      if (pauseTimeout) clearTimeout(pauseTimeout);
      pauseTimeout = setTimeout(() => {
        startAutoplay();
      }, 10000);
    }

    prevBtn.addEventListener('click', () => {
      goToPage(currentPage - 1);
      pauseAutoplay();
    });

    nextBtn.addEventListener('click', () => {
      goToPage(currentPage + 1);
      pauseAutoplay();
    });

    // Touch/swipe
    let startX = 0;
    let isDragging = false;

    track.addEventListener('touchstart', (e) => {
      startX = e.touches[0].clientX;
      isDragging = true;
    }, { passive: true });

    track.addEventListener('touchend', (e) => {
      if (!isDragging) return;
      isDragging = false;
      const diff = startX - e.changedTouches[0].clientX;
      if (Math.abs(diff) > 50) {
        if (diff > 0) goToPage(currentPage + 1);
        else goToPage(currentPage - 1);
        pauseAutoplay();
      }
    });

    // Resize
    let resizeTimer: ReturnType<typeof setTimeout>;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(() => {
        const maxSlide = getMaxSlide();
        if (currentPage > maxSlide) currentPage = maxSlide;
        buildDots();
        goToPage(currentPage);
      }, 150);
    });

    // Init
    buildDots();
    goToPage(0);
    startAutoplay();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initSlider);
  } else {
    initSlider();
  }
</script>
