---
import { Image } from 'astro:assets';

interface Props {
  title: string;
  description: string;
  image: ImageMetadata;
  href: string;
}

const { title, description, image, href } = Astro.props;
---

<a href={href} class="service-card reveal-item">
  <div class="service-card-img">
    <Image
      src={image}
      alt={title}
      width={600}
      height={400}
      format="webp"
      quality={80}
      loading="lazy"
    />
  </div>
  <div class="service-card-overlay"></div>
  <div class="service-card-content">
    <h3>{title}</h3>
    <p class="service-card-desc">{description}</p>
    <span class="service-card-link">Meer info &rarr;</span>
  </div>
</a>

<style>
  .service-card {
    position: relative;
    display: block;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.12);
    text-decoration: none;
    color: var(--color-white);
    background: var(--color-gray-800);
    transition: box-shadow 0.4s ease, transform 0.4s ease;
  }

  .service-card:hover {
    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.22);
    transform: translateY(-3px);
  }

  /* Aspect ratio 3:2 */
  .service-card::before {
    content: '';
    display: block;
    padding-bottom: 66.666%;
  }

  .service-card-img {
    position: absolute;
    inset: 0;
    transition: transform 0.4s ease;
  }

  .service-card:hover .service-card-img {
    transform: scale(1.05);
  }

  .service-card-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Gradient overlay — always present, darkens on hover */
  .service-card-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.72) 0%,
      rgba(0, 0, 0, 0.28) 45%,
      transparent 100%
    );
    transition: background 0.4s ease;
  }

  .service-card:hover .service-card-overlay {
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.88) 0%,
      rgba(0, 0, 0, 0.5) 55%,
      rgba(0, 0, 0, 0.1) 100%
    );
  }

  .service-card-content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 24px;
  }

  h3 {
    font-size: clamp(1.1rem, 2.5vw, 1.3rem);
    font-weight: var(--font-weight-bold);
    color: var(--color-white);
    margin: 0;
    line-height: 1.2;
    transition: transform 0.4s ease;
  }

  .service-card:hover h3 {
    transform: translateY(-4px);
  }

  .service-card-desc {
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.88);
    margin-top: 8px;
    line-height: 1.5;
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.4s ease 0.05s, transform 0.4s ease 0.05s;
  }

  .service-card:hover .service-card-desc {
    opacity: 1;
    transform: translateY(0);
  }

  .service-card-link {
    display: inline-block;
    margin-top: 10px;
    font-size: 0.875rem;
    font-weight: var(--font-weight-semibold);
    color: var(--color-primary-light);
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.4s ease 0.1s, transform 0.4s ease 0.1s;
  }

  .service-card:hover .service-card-link {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .service-card,
    .service-card-img,
    .service-card-overlay,
    h3,
    .service-card-desc,
    .service-card-link {
      transition: none;
    }

    .service-card-desc,
    .service-card-link {
      opacity: 1;
      transform: none;
    }
  }
</style>
