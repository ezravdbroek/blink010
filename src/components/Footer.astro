---
interface Props {
  lang?: 'nl' | 'en';
}

const { lang = 'nl' } = Astro.props;
const p = (path: string) => lang === 'en' ? '/en' + path : path;
---

<footer class="footer">
  <div class="footer-inner">
    <div class="footer-grid">

      <!-- Column 1: Logo + Tagline -->
      <div class="footer-col footer-brand">
        <img src="/logo.png" alt="Blink Schoonmaak 010" class="footer-logo" />
        <p class="footer-tagline">{lang === 'en' ? 'Your reliable cleaning partner in Rotterdam and surrounding areas' : 'Uw betrouwbare schoonmaakpartner in Rotterdam en omgeving'}</p>
      </div>

      <!-- Column 2: Services -->
      <div class="footer-col">
        <h3 class="footer-heading">{lang === 'en' ? 'Services' : 'Diensten'}</h3>
        <ul class="footer-links">
          <li><a href={p('/kantoren-schoonmaak')}>{lang === 'en' ? 'Office Cleaning' : 'Kantoren Schoonmaak'}</a></li>
          <li><a href={p('/particuliere-schoonmaak')}>{lang === 'en' ? 'Home Cleaning' : 'Particuliere Schoonmaak'}</a></li>
          <li><a href={p('/restaurant-schoonmaak')}>{lang === 'en' ? 'Restaurant Cleaning' : 'Restaurant Schoonmaak'}</a></li>
          <li><a href={p('/schoonmaak-recreatiewoning')}>{lang === 'en' ? 'Holiday Home Cleaning' : 'Recreatiewoning Schoonmaak'}</a></li>
          <li><a href={p('/opleveringsschoonmaak')}>{lang === 'en' ? 'End of Tenancy' : 'Opleveringsschoonmaak'}</a></li>
          <li><a href={p('/housekeeping-airbnbs-hotels')}>{lang === 'en' ? 'Housekeeping' : 'Housekeeping'}</a></li>
          <li><a href={p('/glasbewassing')}>{lang === 'en' ? 'Window Cleaning' : 'Glasbewassing'}</a></li>
        </ul>
      </div>

      <!-- Column 3: Navigation -->
      <div class="footer-col">
        <h3 class="footer-heading">{lang === 'en' ? 'Navigation' : 'Navigatie'}</h3>
        <ul class="footer-links">
          <li><a href={p('/')}>{lang === 'en' ? 'Home' : 'Home'}</a></li>
          <li><a href={p('/over-ons')}>{lang === 'en' ? 'About Us' : 'Over Ons'}</a></li>
          <li><a href={p('/offerte-aanvragen')}>{lang === 'en' ? 'Get a Quote' : 'Offerte Aanvragen'}</a></li>
          <li><a href={p('/contact')}>{lang === 'en' ? 'Contact' : 'Contact'}</a></li>
        </ul>
      </div>

      <!-- Column 4: Contact -->
      <div class="footer-col">
        <h3 class="footer-heading">Contact</h3>
        <ul class="footer-contact-list">
          <li>Theodoor Colenbranderhof 5, 3059 LS Rotterdam</li>
          <li>
            <a href="tel:0611125603">0611125603</a>
          </li>
          <li>
            <a href="mailto:info@blinkschoonmaak.nl">info@blinkschoonmaak.nl</a>
          </li>
        </ul>

        <!-- Social Media Icons -->
        <div class="footer-social">
          <a
            href="https://www.instagram.com/blinkschoonmaak010/"
            target="_blank"
            rel="noopener noreferrer"
            aria-label={lang === 'en' ? 'Follow us on Instagram' : 'Volg ons op Instagram'}
            class="social-link"
          >
            <svg viewBox="0 0 24 24" fill="white" width="22" height="22" aria-hidden="true">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
            </svg>
          </a>
          <a
            href="https://wa.me/31611125603"
            target="_blank"
            rel="noopener noreferrer"
            aria-label={lang === 'en' ? 'Send us a WhatsApp message' : 'Stuur ons een WhatsApp bericht'}
            class="social-link"
          >
            <svg viewBox="0 0 24 24" fill="white" width="22" height="22" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
          </a>
        </div>
      </div>

    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="footer-bottom">
    <div class="footer-inner">
      <p>&copy; 2025 Blink Schoonmaak 010 | KVK 94000395 | Gemaakt door <a href="https://www.brandways.nl" target="_blank" rel="noopener noreferrer" class="footer-brandways">Brandways</a></p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: #1a1a1a;
    color: #ccc;
    padding-top: 3.5rem;
  }

  .footer-inner {
    max-width: var(--max-width, 1200px);
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2.5rem;
    padding-bottom: 3rem;
  }

  @media (max-width: 900px) {
    .footer-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 2rem;
    }
  }

  @media (max-width: 540px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
      padding-bottom: 2rem;
    }

    .footer {
      padding-top: 2.5rem;
    }

    .footer-inner {
      padding: 0 1.25rem;
    }

    .footer-contact-list li {
      font-size: 0.875rem;
      word-break: break-word;
    }

    .footer-contact-list a {
      word-break: break-all;
    }
  }

  .footer-col {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  /* Brand column */
  .footer-logo {
    width: 140px;
    height: auto;
    filter: brightness(0) invert(1);
  }

  .footer-tagline {
    font-size: 0.875rem;
    line-height: 1.6;
    color: #ccc;
    margin: 0;
  }

  /* Headings */
  .footer-heading {
    font-size: 1rem;
    font-weight: 700;
    color: #ffffff;
    margin: 0 0 0.25rem 0;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* Link lists */
  .footer-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .footer-links a {
    color: #ccc;
    text-decoration: none;
    font-size: 0.9rem;
    transition: color var(--transition-fast, 0.2s ease);
  }

  .footer-links a:hover {
    color: #00859a;
  }

  /* Contact list */
  .footer-contact-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    font-size: 0.9rem;
  }

  .footer-contact-list li {
    color: #ccc;
    line-height: 1.5;
  }

  .footer-contact-list a {
    color: #ccc;
    text-decoration: none;
    transition: color var(--transition-fast, 0.2s ease);
  }

  .footer-contact-list a:hover {
    color: #00859a;
  }

  /* Social Icons */
  .footer-social {
    display: flex;
    gap: 0.875rem;
    margin-top: 0.25rem;
  }

  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background-color: rgba(255, 255, 255, 0.08);
    transition: background-color var(--transition-fast, 0.2s ease), transform var(--transition-fast, 0.2s ease);
    flex-shrink: 0;
  }

  .social-link:hover {
    background-color: #00859a;
    transform: translateY(-2px);
  }

  /* Bottom bar */
  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding: 1.25rem 0;
    margin-top: 0;
  }

  .footer-bottom p {
    text-align: center;
    font-size: 0.8rem;
    color: #888;
    margin: 0;
  }

  .footer-brandways {
    color: #aaa;
    text-decoration: none;
    transition: color var(--transition-fast, 0.2s ease);
  }

  .footer-brandways:hover {
    color: #00859a;
  }
</style>
