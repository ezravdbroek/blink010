---
---

<form class="contact-form" id="contact-form" novalidate>

  <div class="form-group">
    <label for="naam">Naam *</label>
    <input type="text" id="naam" name="naam" required autocomplete="name" />
  </div>

  <div class="form-group">
    <label for="telefoon">Telefoon *</label>
    <input type="tel" id="telefoon" name="telefoon" required autocomplete="tel" />
  </div>

  <div class="form-group">
    <label for="email">Email *</label>
    <input type="email" id="email" name="email" required autocomplete="email" />
  </div>

  <div class="form-group">
    <label for="bericht">Bericht</label>
    <textarea id="bericht" name="bericht" rows="5"></textarea>
  </div>

  <div class="form-error" id="form-error" hidden>
    Er is iets misgegaan. Probeer het opnieuw.
  </div>

  <button type="submit" class="btn btn-primary form-submit">Versturen</button>
</form>

<div class="form-success" id="form-success" hidden>
  <div class="success-icon">&#10003;</div>
  <h3>Bedankt!</h3>
  <p>We nemen zo snel mogelijk contact met u op.</p>
</div>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const successEl = document.getElementById('form-success') as HTMLElement | null;
  const errorEl = document.getElementById('form-error') as HTMLElement | null;

  if (form) {
    form.addEventListener('submit', async (e: Event) => {
      e.preventDefault();

      const submitBtn = form.querySelector('.form-submit') as HTMLButtonElement | null;
      if (errorEl) errorEl.hidden = true;

      if (submitBtn) {
        submitBtn.textContent = 'Verzenden...';
        submitBtn.disabled = true;
      }

      try {
        const formData = new FormData(form);
        const response = await fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            naam: formData.get('naam'),
            telefoon: formData.get('telefoon'),
            email: formData.get('email'),
            bericht: formData.get('bericht'),
          }),
        });

        if (response.ok) {
          form.hidden = true;
          if (successEl) successEl.hidden = false;
        } else {
          throw new Error('Server responded with an error');
        }
      } catch {
        if (errorEl) errorEl.hidden = false;
        if (submitBtn) {
          submitBtn.textContent = 'Versturen';
          submitBtn.disabled = false;
        }
      }
    });
  }
</script>

<style>
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .form-group label {
    font-weight: var(--font-weight-semibold);
    font-size: 0.95rem;
    color: var(--color-gray-800);
  }

  .form-group input,
  .form-group textarea {
    width: 100%;
    padding: 12px 16px;
    border: 1px solid #e0e0e0;
    border-radius: 8px;
    font-size: 1rem;
    font-family: var(--font-family);
    color: var(--color-black);
    background: var(--color-white);
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
    outline: none;
  }

  .form-group input:focus,
  .form-group textarea:focus {
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px rgba(0, 133, 154, 0.15);
  }

  .form-group textarea {
    min-height: 120px;
    resize: vertical;
  }

  .form-error {
    background: #fff3f3;
    border: 1px solid #f5c6c6;
    border-radius: 8px;
    padding: 12px 16px;
    color: #c0392b;
    font-size: 0.95rem;
  }

  .form-submit {
    width: 100%;
    justify-content: center;
    cursor: pointer;
  }

  .form-submit:disabled {
    opacity: 0.65;
    cursor: not-allowed;
    transform: none;
    box-shadow: none;
  }

  .form-success {
    text-align: center;
    padding: 40px 24px;
  }

  .success-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 64px;
    height: 64px;
    background: var(--color-primary);
    color: var(--color-white);
    border-radius: 50%;
    font-size: 1.75rem;
    font-weight: var(--font-weight-bold);
    margin-bottom: 20px;
  }

  .form-success h3 {
    font-size: 1.5rem;
    color: var(--color-gray-800);
    margin-bottom: 8px;
  }

  .form-success p {
    color: var(--color-gray-400);
    font-size: 1rem;
  }
</style>
