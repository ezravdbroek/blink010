<script>
  // ============================================================
  // SCROLL BEHAVIOR
  // ============================================================
  const nav = document.getElementById('main-nav') as HTMLElement;

  function updateNavScroll() {
    if (window.scrollY > 50) {
      nav.classList.add('scrolled');
    } else {
      nav.classList.remove('scrolled');
    }
  }

  // Initial check (in case page loads already scrolled)
  updateNavScroll();
  window.addEventListener('scroll', updateNavScroll, { passive: true });

  // ============================================================
  // DESKTOP MEGA MENU
  // ============================================================
  const dienstenBtn  = document.getElementById('diensten-btn')  as HTMLButtonElement;
  const dienstenMenu = document.getElementById('diensten-menu') as HTMLElement;
  const dienstenItem = dienstenBtn?.closest('.nav-item-dropdown') as HTMLElement;

  const isMobile = () => window.innerWidth <= 1024;

  function openMega() {
    if (isMobile()) return;
    dienstenItem.classList.add('open');
    dienstenMenu.classList.add('open');
    dienstenMenu.setAttribute('aria-hidden', 'false');
    dienstenBtn.setAttribute('aria-expanded', 'true');
    // Ensure nav has solid background while dropdown is open
    nav.classList.add('scrolled');
  }

  function closeMega() {
    dienstenItem.classList.remove('open');
    dienstenMenu.classList.remove('open');
    dienstenMenu.setAttribute('aria-hidden', 'true');
    dienstenBtn.setAttribute('aria-expanded', 'false');
    // Only remove solid background if user hasn't scrolled past 50px
    if (window.scrollY <= 50) {
      nav.classList.remove('scrolled');
    }
  }

  if (dienstenBtn && dienstenItem && dienstenMenu) {
    // Open on hover over the trigger item
    dienstenItem.addEventListener('mouseenter', openMega);
    dienstenItem.addEventListener('mouseleave', () => {
      // Give a brief moment so cursor can travel into the mega menu
      setTimeout(() => {
        if (!dienstenMenu.matches(':hover')) closeMega();
      }, 80);
    });

    // Keep open while hovering the mega menu itself
    dienstenMenu.addEventListener('mouseenter', openMega);
    dienstenMenu.addEventListener('mouseleave', closeMega);

    // Keyboard: Enter/Space toggles
    dienstenBtn.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        dienstenItem.classList.contains('open') ? closeMega() : openMega();
      }
    });

    // Keyboard: Escape closes
    dienstenItem.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') { closeMega(); dienstenBtn.focus(); }
    });
    dienstenMenu.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') { closeMega(); dienstenBtn.focus(); }
    });

    // Close when clicking outside
    document.addEventListener('click', (e) => {
      if (
        !dienstenItem.contains(e.target as Node) &&
        !dienstenMenu.contains(e.target as Node)
      ) {
        closeMega();
      }
    });
  }

  // ============================================================
  // MOBILE MENU
  // ============================================================
  const hamburger        = document.getElementById('hamburger-btn')      as HTMLButtonElement;
  const mobileMenu       = document.getElementById('mobile-menu')        as HTMLElement;
  const mobileCloseBtn   = document.getElementById('mobile-close-btn')   as HTMLButtonElement;
  const mobileCloseBtnAlt = document.getElementById('mobile-close-btn-alt') as HTMLButtonElement;

  function openMobileMenu() {
    mobileMenu.classList.add('open');
    mobileMenu.setAttribute('aria-hidden', 'false');
    hamburger.setAttribute('aria-expanded', 'true');
    hamburger.setAttribute('aria-label', hamburger.dataset.closeLabel || 'Menu sluiten');
    document.body.style.overflow = 'hidden';
    document.documentElement.style.overflow = 'hidden';
    mobileCloseBtn.focus();
  }

  function closeMobileMenu() {
    // Also reset diensten panel when closing
    mobileMenu.classList.remove('open', 'diensten-open');
    mobileMenu.setAttribute('aria-hidden', 'true');
    hamburger.setAttribute('aria-expanded', 'false');
    hamburger.setAttribute('aria-label', hamburger.dataset.openLabel || 'Menu openen');
    document.body.style.overflow = '';
    document.documentElement.style.overflow = '';
    hamburger.focus();
  }

  hamburger?.addEventListener('click', () => {
    const isOpen = mobileMenu.classList.contains('open');
    isOpen ? closeMobileMenu() : openMobileMenu();
  });

  mobileCloseBtn?.addEventListener('click', closeMobileMenu);
  mobileCloseBtnAlt?.addEventListener('click', closeMobileMenu);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && mobileMenu.classList.contains('open')) {
      if (mobileMenu.classList.contains('diensten-open')) {
        // Escape from diensten panel goes back to main panel
        closeDienstenPanel();
      } else {
        closeMobileMenu();
      }
    }
  });

  // Close menu when a service link is clicked (navigating away)
  mobileMenu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', closeMobileMenu);
  });

  // ============================================================
  // MOBILE TWO-PANEL: DIENSTEN
  // ============================================================
  const mobileDienstenTrigger = document.getElementById('mobile-diensten-trigger') as HTMLButtonElement;
  const mobileBackBtn         = document.getElementById('mobile-back-btn')         as HTMLButtonElement;

  function openDienstenPanel() {
    mobileMenu.classList.add('diensten-open');
    // Move focus to back button for accessibility
    mobileBackBtn?.focus();
  }

  function closeDienstenPanel() {
    mobileMenu.classList.remove('diensten-open');
    mobileDienstenTrigger?.focus();
  }

  mobileDienstenTrigger?.addEventListener('click', openDienstenPanel);
  mobileBackBtn?.addEventListener('click', closeDienstenPanel);
</script>
