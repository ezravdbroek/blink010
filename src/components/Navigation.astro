        </li>
        <li>
          <a href="/contact" class="mobile-nav-link">Contact</a>
        </li>
        <li>
          <a href="/offerte-aanvragen" class="mobile-nav-link mobile-nav-cta">Offerte Aanvragen</a>
        </li>
      </ul>
    </nav>
  </div>

  <!-- ── Panel 2: Diensten sub-menu ── -->
