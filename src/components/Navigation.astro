---
// Navigation.astro — Sticky transparent navbar with scroll transition
---

<nav class="nav" id="main-nav" aria-label="Hoofdnavigatie">
  <div class="nav-inner">

    <!-- Logo -->
    <a href="/" class="nav-logo" aria-label="Blink Schoonmaak 010 — terug naar home">
      <img src="/logo.png" alt="Blink Schoonmaak 010" width="140" height="40" />
    </a>

    <!-- Desktop menu -->
    <ul class="nav-links" role="list">
      <li>
        <a href="/" class="nav-link">Home</a>
      </li>

      <!-- Diensten mega menu trigger -->
      <li class="nav-item-dropdown">
        <button
          class="nav-link nav-link-dropdown"
          aria-haspopup="true"
          aria-expanded="false"
          id="diensten-btn"
        >
          Diensten
          <svg class="dropdown-chevron" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path d="M2 5l5 5 5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </li>

      <li>
        <a href="/over-ons" class="nav-link">Over Ons</a>
      </li>
      <li>
        <a href="/contact" class="nav-link">Contact</a>
      </li>
      <li>
        <a href="/offerte-aanvragen" class="nav-link nav-link-cta">Offerte Aanvragen</a>
      </li>
    </ul>

    <!-- Hamburger button (mobile) -->
    <button
      class="hamburger"
      id="hamburger-btn"
      aria-label="Menu openen"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
    </button>
  </div>
</nav>

<!-- Mega menu — full-width, positioned below the nav bar -->
<div class="mega-menu" id="diensten-menu" role="region" aria-labelledby="diensten-btn" aria-hidden="true">
  <div class="mega-menu-inner">
    <ul class="mega-grid" role="list">

      <li class="mega-item" style="--i:0">
        <a href="/kantoren-schoonmaak" class="mega-card">
          <span class="mega-icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#00859a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/><path d="M7 6h.01"/><path d="M12 6h.01"/><path d="M17 6h.01"/>
            </svg>
          </span>
          <span class="mega-title">Kantoren Schoonmaak</span>
          <span class="mega-desc">Professionele kantoorschoonmaak</span>
        </a>
      </li>

      <li class="mega-item" style="--i:1">
        <a href="/particuliere-schoonmaak" class="mega-card">
          <span class="mega-icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#00859a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>
            </svg>
          </span>
          <span class="mega-title">Particuliere Schoonmaak</span>
          <span class="mega-desc">Huishoudelijke schoonmaak op maat</span>
        </a>
      </li>

      <li class="mega-item" style="--i:2">
        <a href="/restaurant-schoonmaak" class="mega-card">
          <span class="mega-icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#00859a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 2v7c0 1.1.9 2 2 2h4a2 2 0 002-2V2"/><path d="M7 2v20"/><path d="M21 15V2a5 5 0 00-5 5v6c0 1.1.9 2 2 2h3zm0 0v7"/>
            </svg>
          </span>
          <span class="mega-title">Restaurant Schoonmaak</span>
          <span class="mega-desc">Hygiënische horeca reiniging</span>
        </a>
      </li>

      <li class="mega-item" style="--i:3">
        <a href="/schoonmaak-recreatiewoning" class="mega-card">
          <span class="mega-icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#00859a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><circle cx="12" cy="13" r="2"/><path d="M12 15v4"/>
            </svg>
          </span>
          <span class="mega-title">Recreatiewoning Schoonmaak</span>
          <span class="mega-desc">Vakantiewoning altijd gastklaar</span>
        </a>
      </li>

      <li class="mega-item" style="--i:4">
        <a href="/opleveringsschoonmaak" class="mega-card">
          <span class="mega-icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#00859a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2l1.5 4.5L18 8l-4.5 1.5L12 14l-1.5-4.5L6 8l4.5-1.5z"/><path d="M5 16l1 3 3-1"/><path d="M19 16l-1 3-3-1"/>
            </svg>
          </span>
          <span class="mega-title">Opleveringsschoonmaak</span>
          <span class="mega-desc">Grondige opleveringsreiniging</span>
        </a>
      </li>

    </ul>
  </div>
</div>

<!-- Mobile fullscreen menu -->
<div
  class="mobile-menu"
  id="mobile-menu"
  role="dialog"
  aria-modal="true"
  aria-label="Mobiel menu"
  aria-hidden="true"
>
