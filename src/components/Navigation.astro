<style>
  /* ============================================================
     NAV BASE
     ============================================================ */
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    height: var(--nav-height);
    background: transparent;
    transition:
      background var(--transition-medium),
      box-shadow var(--transition-medium);
  }

  .nav.scrolled {
    background: var(--color-white) !important;
    box-shadow: 0 2px 20px rgba(0, 0, 0, 0.08);
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 24px;
  }

  /* ============================================================
     LOGO
     ============================================================ */
  .nav-logo {
    display: flex;
    align-items: center;
    flex-shrink: 0;
    line-height: 0;
  }

  .nav-logo img {
    height: 50px;
    width: auto;
    transition: filter var(--transition-medium);
  }

  @media (max-width: 480px) {
    .nav-logo img {
      height: 40px;
    }
  }

  /* White logo invisible on white bg — make it black */
  .nav.scrolled .nav-logo img {
    filter: brightness(0);
  }

  /* ============================================================
     DESKTOP NAV LINKS
     ============================================================ */
  .nav-links {
    display: flex;
    align-items: center;
    gap: 4px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-link {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 8px 14px;
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-white);
    background: none;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    transition: color var(--transition-medium);
    white-space: nowrap;
  }

  /* Underline grows from center */
  .nav-link:not(.nav-link-cta)::after {
    content: '';
    position: absolute;
    bottom: 4px;
    left: 50%;
    transform: translateX(-50%) scaleX(0);
    transform-origin: center;
    width: calc(100% - 28px);
    height: 2px;
    background: currentColor;
    border-radius: 1px;
    transition: transform var(--transition-fast);
  }

  .nav-link:not(.nav-link-cta):hover::after,
  .nav-link:not(.nav-link-cta):focus-visible::after {
    transform: translateX(-50%) scaleX(1);
  }

  /* Color flip on scrolled state */
  .nav.scrolled .nav-link:not(.nav-link-cta) {
    color: var(--color-black);
  }

  /* ============================================================
     CTA BUTTON
     ============================================================ */
  .nav-link-cta {
    background: var(--color-primary);
    color: var(--color-white) !important;
    padding: 10px 20px;
    border-radius: 8px;
    box-shadow: 0 4px 14px rgba(0, 133, 154, 0.35);
    transition:
      background var(--transition-fast),
      box-shadow var(--transition-fast),
      transform var(--transition-fast);
  }

  .nav-link-cta:hover {
    background: var(--color-primary-dark);
    box-shadow: 0 6px 20px rgba(0, 133, 154, 0.5);
    transform: translateY(-1px);
  }

  .nav-link-cta:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 3px;
  }

  /* ============================================================
     DROPDOWN TRIGGER (chevron)
     ============================================================ */
  .nav-item-dropdown {
    list-style: none;
  }

  .dropdown-chevron {
    transition: transform var(--transition-fast);
    flex-shrink: 0;
  }

  .nav-item-dropdown.open .dropdown-chevron {
    transform: rotate(180deg);
  }

  /* ============================================================
     MEGA MENU — full-width overlay panel
     ============================================================ */
  .mega-menu {
    position: fixed;
    top: var(--nav-height);
    left: 0;
    right: 0;
    width: 100vw;
    z-index: 999;
    background: white;
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.1);
    border-top: 1px solid rgba(0, 0, 0, 0.05);

    /* Hidden by default — slide-down animation */
    max-height: 0;
    overflow: hidden;
    opacity: 0;
    pointer-events: none;
    transition:
      max-height 0.35s ease,
      opacity 0.25s ease;
  }

  /* Visible state toggled via JS (.open class on nav-item-dropdown AND mega-menu) */
  .mega-menu.open {
    max-height: 400px;
    opacity: 1;
    pointer-events: auto;
  }

  .mega-menu-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 32px 24px;
  }

  /* 5-column grid */
  .mega-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 12px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  /* Stagger animation for each item — instant close, staggered open */
  .mega-item {
    opacity: 0;
    transform: translateY(6px);
    /* No delay on close — items disappear instantly */
    transition:
      opacity 0s ease,
      transform 0s ease;
  }

  .mega-menu.open .mega-item {
    opacity: 1;
    transform: translateY(0);
    /* Stagger delay only applies when opening */
    transition:
      opacity 0.22s ease calc(var(--i) * 0.05s + 0.1s),
      transform 0.22s ease calc(var(--i) * 0.05s + 0.1s);
  }

  /* Card */
  .mega-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 22px 16px 20px;
    border-radius: 12px;
    text-decoration: none;
    border: 2px solid transparent;
    transition:
      border-color 0.18s ease,
      transform 0.18s ease,
      background 0.18s ease;
  }

  .mega-card:hover,
  .mega-card:focus-visible {
    border-color: #00859a;
    transform: translateY(-2px);
    background: rgba(0, 133, 154, 0.02);
  }

  .mega-card:focus-visible {
    outline: 2px solid #00859a;
    outline-offset: 2px;
  }

  /* Icon circle */
  .mega-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: rgba(0, 133, 154, 0.08);
    margin-bottom: 14px;
    flex-shrink: 0;
    transition: background 0.18s ease;
  }

  .mega-card:hover .mega-icon,
  .mega-card:focus-visible .mega-icon {
    background: rgba(0, 133, 154, 0.16);
  }

  /* Title */
  .mega-title {
    display: block;
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-black);
    line-height: 1.3;
    margin-bottom: 6px;
    transition: color 0.18s ease;
  }

  .mega-card:hover .mega-title,
  .mega-card:focus-visible .mega-title {
    color: #00859a;
  }

  /* Description */
  .mega-desc {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    font-size: 0.82rem;
    font-weight: 400;
    color: #888;
    line-height: 1.45;
  }

  /* ============================================================
     HAMBURGER (hidden on desktop)
     ============================================================ */
  .hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 5px;
    width: 44px;
    height: 44px;
    padding: 8px;
    border-radius: 8px;
    background: none;
    border: none;
    cursor: pointer;
    transition: background var(--transition-fast);
  }

  .hamburger:hover {
    background: rgba(255, 255, 255, 0.15);
  }

  .nav.scrolled .hamburger:hover {
    background: var(--color-gray-50);
  }

  .hamburger-line {
    display: block;
    width: 22px;
    height: 2px;
    border-radius: 2px;
    background: var(--color-white);
    transition:
      transform var(--transition-fast),
      opacity var(--transition-fast),
      background var(--transition-medium);
  }

  .nav.scrolled .hamburger-line {
    background: var(--color-black);
  }

  /* Animate to X when open */
  .hamburger[aria-expanded="true"] .hamburger-line:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }

  .hamburger[aria-expanded="true"] .hamburger-line:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }

  .hamburger[aria-expanded="true"] .hamburger-line:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* ============================================================
     MOBILE FULLSCREEN MENU
     ============================================================ */
  .mobile-menu {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    width: 100%;
    max-width: 100%;
    z-index: 1002;
    background: #fff;
    display: flex;
    flex-direction: row;
    /* Clip the two sliding panels */
    overflow: hidden;
    /* Hidden by default — slide in from right */
    transform: translateX(100%);
    transition: transform 0.35s ease;
  }

  .mobile-menu.open {
    transform: translateX(0);
  }

  /* ── Shared panel base ── */
  .mobile-panel {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    background: #fff;
    overflow-y: auto;
    overscroll-behavior: contain;
    /* Panels slide horizontally */
    transition: transform 0.3s ease;
  }

  /* Panel 1 sits at position 0 (visible) */
  #mobile-panel-main {
    transform: translateX(0);
  }

  /* Panel 2 sits off-screen to the right */
  .mobile-panel-diensten {
    transform: translateX(100%);
  }

  /* When diensten panel is active, slide panel 1 left and panel 2 into view */
  .mobile-menu.diensten-open #mobile-panel-main {
    transform: translateX(-100%);
  }

  .mobile-menu.diensten-open .mobile-panel-diensten {
    transform: translateX(0);
  }

  /* ── Header shared by both panels ── */
  .mobile-menu-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px 20px 16px;
    border-bottom: 1px solid var(--color-gray-100);
    flex-shrink: 0;
  }

  .mobile-logo img {
    height: 34px;
    width: auto;
    filter: brightness(0);
  }

  .mobile-close {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 8px;
    color: var(--color-black);
    background: none;
    border: none;
    cursor: pointer;
    transition: background var(--transition-fast);
    flex-shrink: 0;
  }

  .mobile-close:hover {
    background: var(--color-gray-50);
  }

  /* Back button in panel 2 */
  .mobile-back-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 12px;
    border-radius: 8px;
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-primary);
    background: none;
    border: none;
    cursor: pointer;
    transition: background var(--transition-fast);
  }

  .mobile-back-btn:hover {
    background: rgba(0, 133, 154, 0.06);
  }

  /* ── Panel 1: Main nav list ── */
  .mobile-nav-list {
    list-style: none;
    padding: 16px 16px 32px;
    margin: 0;
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 4px;
  }

  .mobile-nav-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: 16px 18px;
    border-radius: 10px;
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--color-black);
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
    text-decoration: none;
    transition: background var(--transition-fast), color var(--transition-fast);
  }

  .mobile-nav-link:hover,
  .mobile-nav-link:focus-visible {
    background: var(--color-gray-50);
    color: var(--color-primary);
  }

  .mobile-nav-link:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }

  .mobile-diensten-trigger {
    color: var(--color-black);
  }

  .mobile-arrow-right {
    flex-shrink: 0;
    color: #aaa;
  }

  .mobile-nav-cta {
    margin-top: 12px;
    background: var(--color-primary) !important;
    color: var(--color-white) !important;
    border-radius: 10px;
    justify-content: center;
    box-shadow: 0 4px 14px rgba(0, 133, 154, 0.3);
  }

  .mobile-nav-cta:hover {
    background: var(--color-primary-dark) !important;
    color: var(--color-white) !important;
  }

  /* ── Panel 2: Diensten sub-list ── */
  .diensten-panel-title {
    padding: 20px 20px 8px;
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--color-black);
    flex-shrink: 0;
  }

  .mobile-diensten-list {
    list-style: none;
    padding: 8px 16px 32px;
    margin: 0;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .mobile-diensten-link {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 14px 16px;
    border-radius: 10px;
    text-decoration: none;
    transition: background var(--transition-fast);
  }

  .mobile-diensten-link:hover,
  .mobile-diensten-link:focus-visible {
    background: rgba(0, 133, 154, 0.05);
  }

  .mobile-diensten-link:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }

  .mobile-diensten-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: rgba(0, 133, 154, 0.08);
    flex-shrink: 0;
    transition: background var(--transition-fast);
  }

  .mobile-diensten-link:hover .mobile-diensten-icon {
    background: rgba(0, 133, 154, 0.15);
  }

  .mobile-diensten-text {
    display: flex;
    flex-direction: column;
    gap: 2px;
    flex: 1;
    min-width: 0;
  }

  .mobile-diensten-name {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-black);
    line-height: 1.3;
    transition: color var(--transition-fast);
  }

  .mobile-diensten-link:hover .mobile-diensten-name {
    color: var(--color-primary);
  }

  .mobile-diensten-desc {
    font-size: 0.85rem;
    font-weight: 400;
    color: #888;
    line-height: 1.4;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .mobile-diensten-chevron {
    flex-shrink: 0;
  }

  /* ============================================================
     RESPONSIVE — show hamburger, hide desktop links + mega menu
     ============================================================ */
  @media (max-width: 1024px) {
    .nav-links {
      display: none;
    }

    .hamburger {
      display: flex;
    }

    /* Mega menu never shows on mobile — mobile panel handles it */
    .mega-menu {
      display: none !important;
    }
  }

  @media (max-width: 768px) {
    .nav {
      height: var(--nav-height);
      padding: 0 20px;
    }

    .nav.scrolled {
      background: #ffffff !important;
      box-shadow: 0 2px 20px rgba(0, 0, 0, 0.08) !important;
    }

    .nav.scrolled .nav-logo img {
      filter: brightness(0) !important;
    }

    .nav.scrolled .hamburger span {
      background: var(--color-black) !important;
    }

    .nav-logo img {
      height: 44px;
      width: auto;
    }

    .hamburger {
      flex-shrink: 0;
    }
  }
</style>

<script>
  // ============================================================
  // SCROLL BEHAVIOR
  // ============================================================
  const nav = document.getElementById('main-nav') as HTMLElement;

  function updateNavScroll() {
    if (window.scrollY > 50) {
      nav.classList.add('scrolled');
    } else {
      nav.classList.remove('scrolled');
    }
  }

  // Initial check (in case page loads already scrolled)
  updateNavScroll();
  window.addEventListener('scroll', updateNavScroll, { passive: true });

  // ============================================================
  // DESKTOP MEGA MENU
  // ============================================================
  const dienstenBtn  = document.getElementById('diensten-btn')  as HTMLButtonElement;
  const dienstenMenu = document.getElementById('diensten-menu') as HTMLElement;
  const dienstenItem = dienstenBtn?.closest('.nav-item-dropdown') as HTMLElement;

  const isMobile = () => window.innerWidth <= 1024;

  function openMega() {
    if (isMobile()) return;
    dienstenItem.classList.add('open');
    dienstenMenu.classList.add('open');
    dienstenMenu.setAttribute('aria-hidden', 'false');
    dienstenBtn.setAttribute('aria-expanded', 'true');
    // Ensure nav has solid background while dropdown is open
    nav.classList.add('scrolled');
  }

  function closeMega() {
    dienstenItem.classList.remove('open');
    dienstenMenu.classList.remove('open');
    dienstenMenu.setAttribute('aria-hidden', 'true');
    dienstenBtn.setAttribute('aria-expanded', 'false');
    // Only remove solid background if user hasn't scrolled past 50px
    if (window.scrollY <= 50) {
      nav.classList.remove('scrolled');
    }
  }

  if (dienstenBtn && dienstenItem && dienstenMenu) {
    // Open on hover over the trigger item
    dienstenItem.addEventListener('mouseenter', openMega);
    dienstenItem.addEventListener('mouseleave', () => {
      // Give a brief moment so cursor can travel into the mega menu
      setTimeout(() => {
        if (!dienstenMenu.matches(':hover')) closeMega();
      }, 80);
    });

    // Keep open while hovering the mega menu itself
    dienstenMenu.addEventListener('mouseenter', openMega);
    dienstenMenu.addEventListener('mouseleave', closeMega);

    // Keyboard: Enter/Space toggles
    dienstenBtn.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        dienstenItem.classList.contains('open') ? closeMega() : openMega();
      }
    });

    // Keyboard: Escape closes
    dienstenItem.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') { closeMega(); dienstenBtn.focus(); }
    });
    dienstenMenu.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') { closeMega(); dienstenBtn.focus(); }
    });

    // Close when clicking outside
    document.addEventListener('click', (e) => {
      if (
        !dienstenItem.contains(e.target as Node) &&
        !dienstenMenu.contains(e.target as Node)
      ) {
        closeMega();
      }
    });
  }

  // ============================================================
  // MOBILE MENU
  // ============================================================
  const hamburger        = document.getElementById('hamburger-btn')      as HTMLButtonElement;
  const mobileMenu       = document.getElementById('mobile-menu')        as HTMLElement;
  const mobileCloseBtn   = document.getElementById('mobile-close-btn')   as HTMLButtonElement;
  const mobileCloseBtnAlt = document.getElementById('mobile-close-btn-alt') as HTMLButtonElement;

  function openMobileMenu() {
    mobileMenu.classList.add('open');
    mobileMenu.setAttribute('aria-hidden', 'false');
    hamburger.setAttribute('aria-expanded', 'true');
    hamburger.setAttribute('aria-label', 'Menu sluiten');
    document.body.style.overflow = 'hidden';
    mobileCloseBtn.focus();
  }

  function closeMobileMenu() {
    // Also reset diensten panel when closing
    mobileMenu.classList.remove('open', 'diensten-open');
    mobileMenu.setAttribute('aria-hidden', 'true');
    hamburger.setAttribute('aria-expanded', 'false');
    hamburger.setAttribute('aria-label', 'Menu openen');
    document.body.style.overflow = '';
    hamburger.focus();
  }

  hamburger?.addEventListener('click', () => {
    const isOpen = mobileMenu.classList.contains('open');
    isOpen ? closeMobileMenu() : openMobileMenu();
  });

  mobileCloseBtn?.addEventListener('click', closeMobileMenu);
  mobileCloseBtnAlt?.addEventListener('click', closeMobileMenu);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && mobileMenu.classList.contains('open')) {
      if (mobileMenu.classList.contains('diensten-open')) {
        // Escape from diensten panel goes back to main panel
        closeDienstenPanel();
      } else {
        closeMobileMenu();
      }
    }
  });

  // Close menu when a service link is clicked (navigating away)
  mobileMenu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', closeMobileMenu);
  });

  // ============================================================
  // MOBILE TWO-PANEL: DIENSTEN
  // ============================================================
  const mobileDienstenTrigger = document.getElementById('mobile-diensten-trigger') as HTMLButtonElement;
  const mobileBackBtn         = document.getElementById('mobile-back-btn')         as HTMLButtonElement;

  function openDienstenPanel() {
    mobileMenu.classList.add('diensten-open');
    // Move focus to back button for accessibility
    mobileBackBtn?.focus();
  }

  function closeDienstenPanel() {
    mobileMenu.classList.remove('diensten-open');
    mobileDienstenTrigger?.focus();
  }

  mobileDienstenTrigger?.addEventListener('click', openDienstenPanel);
  mobileBackBtn?.addEventListener('click', closeDienstenPanel);
</script>
