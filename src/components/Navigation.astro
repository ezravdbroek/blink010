---
// Navigation.astro — Sticky transparent navbar with scroll transition
---

<nav class="nav" id="main-nav" aria-label="Hoofdnavigatie">
  <div class="nav-inner">

    <!-- Logo -->
    <a href="/" class="nav-logo" aria-label="Blink Schoonmaak 010 — terug naar home">
      <img src="/logo.png" alt="Blink Schoonmaak 010" width="140" height="40" />
    </a>

    <!-- Desktop menu -->
    <ul class="nav-links" role="list">
      <li>
        <a href="/" class="nav-link">Home</a>
      </li>

      <!-- Diensten mega menu trigger -->
      <li class="nav-item-dropdown">
        <button
          class="nav-link nav-link-dropdown"
          aria-haspopup="true"
          aria-expanded="false"
          id="diensten-btn"
        >
          Diensten
          <svg class="dropdown-chevron" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path d="M2 5l5 5 5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </li>

      <li>
        <a href="/over-ons" class="nav-link">Over Ons</a>
      </li>
      <li>
        <a href="/contact" class="nav-link">Contact</a>
      </li>
      <li>
        <a href="/offerte-aanvragen" class="nav-link nav-link-cta">Offerte Aanvragen</a>
      </li>
    </ul>

    <!-- Hamburger button (mobile) -->
    <button
      class="hamburger"
      id="hamburger-btn"
      aria-label="Menu openen"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
    </button>
  </div>
</nav>

<!-- Mega menu — full-width, positioned below the nav bar -->
<div class="mega-menu" id="diensten-menu" role="region" aria-labelledby="diensten-btn" aria-hidden="true">
  <div class="mega-menu-inner">
    <ul class="mega-grid" role="list">

      <li class="mega-item" style="--i:0">
        <a href="/kantoren-schoonmaak" class="mega-card">
          <span class="mega-icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#00859a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/><path d="M7 6h.01"/><path d="M12 6h.01"/><path d="M17 6h.01"/>
            </svg>
          </span>
          <span class="mega-title">Kantoren Schoonmaak</span>
          <span class="mega-desc">Professionele kantoorschoonmaak</span>
        </a>
      </li>

      <li class="mega-item" style="--i:1">
        <a href="/particuliere-schoonmaak" class="mega-card">
          <span class="mega-icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#00859a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>
            </svg>
          </span>
          <span class="mega-title">Particuliere Schoonmaak</span>
          <span class="mega-desc">Huishoudelijke schoonmaak op maat</span>
        </a>
      </li>

      <li class="mega-item" style="--i:2">
        <a href="/restaurant-schoonmaak" class="mega-card">
          <span class="mega-icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#00859a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 2v7c0 1.1.9 2 2 2h4a2 2 0 002-2V2"/><path d="M7 2v20"/><path d="M21 15V2a5 5 0 00-5 5v6c0 1.1.9 2 2 2h3zm0 0v7"/>
            </svg>
          </span>
          <span class="mega-title">Restaurant Schoonmaak</span>
          <span class="mega-desc">Hygiënische horeca reiniging</span>
        </a>
      </li>

      <li class="mega-item" style="--i:3">
        <a href="/schoonmaak-recreatiewoning" class="mega-card">
          <span class="mega-icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#00859a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><circle cx="12" cy="13" r="2"/><path d="M12 15v4"/>
            </svg>
          </span>
          <span class="mega-title">Recreatiewoning Schoonmaak</span>
          <span class="mega-desc">Vakantiewoning altijd gastklaar</span>
        </a>
      </li>

      <li class="mega-item" style="--i:4">
        <a href="/opleveringsschoonmaak" class="mega-card">
          <span class="mega-icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#00859a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2l1.5 4.5L18 8l-4.5 1.5L12 14l-1.5-4.5L6 8l4.5-1.5z"/><path d="M5 16l1 3 3-1"/><path d="M19 16l-1 3-3-1"/>
            </svg>
          </span>
          <span class="mega-title">Opleveringsschoonmaak</span>
          <span class="mega-desc">Grondige opleveringsreiniging</span>
        </a>
      </li>

    </ul>
  </div>
</div>

<!-- Mobile slide-in panel -->
<div class="mobile-overlay" id="mobile-overlay" aria-hidden="true"></div>
<div
  class="mobile-menu"
  id="mobile-menu"
  role="dialog"
  aria-modal="true"
  aria-label="Mobiel menu"
  aria-hidden="true"
>
  <div class="mobile-menu-header">
    <a href="/" class="mobile-logo" aria-label="Blink Schoonmaak 010 — home">
      <img src="/logo.png" alt="Blink Schoonmaak 010" width="120" height="34" />
    </a>
    <button
      class="mobile-close"
      id="mobile-close-btn"
      aria-label="Menu sluiten"
    >
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
        <line x1="18" y1="6" x2="6" y2="18"/>
        <line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
  </div>

  <nav aria-label="Mobiele navigatie">
    <ul class="mobile-nav-list" role="list">
      <li>
        <a href="/" class="mobile-nav-link">Home</a>
      </li>

      <!-- Diensten accordion -->
      <li class="mobile-item-accordion">
        <button
          class="mobile-nav-link mobile-accordion-btn"
          aria-expanded="false"
          id="mobile-diensten-btn"
          aria-controls="mobile-diensten-list"
        >
          Diensten
          <svg class="accordion-chevron" width="16" height="16" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path d="M2 5l5 5 5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <ul class="mobile-submenu" id="mobile-diensten-list" aria-labelledby="mobile-diensten-btn" hidden>
          <li><a href="/kantoren-schoonmaak" class="mobile-sub-link">Kantoren Schoonmaak</a></li>
          <li><a href="/particuliere-schoonmaak" class="mobile-sub-link">Particuliere Schoonmaak</a></li>
          <li><a href="/restaurant-schoonmaak" class="mobile-sub-link">Restaurant Schoonmaak</a></li>
          <li><a href="/schoonmaak-recreatiewoning" class="mobile-sub-link">Recreatiewoning Schoonmaak</a></li>
          <li><a href="/opleveringsschoonmaak" class="mobile-sub-link">Opleveringsschoonmaak</a></li>
        </ul>
      </li>

      <li>
        <a href="/over-ons" class="mobile-nav-link">Over Ons</a>
      </li>
      <li>
        <a href="/contact" class="mobile-nav-link">Contact</a>
      </li>
      <li>
        <a href="/offerte-aanvragen" class="mobile-nav-link mobile-nav-cta">Offerte Aanvragen</a>
      </li>
    </ul>
  </nav>
</div>

<style>
  /* ============================================================
     NAV BASE
     ============================================================ */
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    height: var(--nav-height);
    background: transparent;
    transition:
      background var(--transition-medium),
      box-shadow var(--transition-medium);
  }

  .nav.scrolled {
    background: var(--color-white);
    box-shadow: 0 2px 20px rgba(0, 0, 0, 0.08);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 24px;
  }

  /* ============================================================
     LOGO
     ============================================================ */
  .nav-logo {
    display: flex;
    align-items: center;
    flex-shrink: 0;
    line-height: 0;
  }

  .nav-logo img {
    height: 50px;
    width: auto;
    transition: filter var(--transition-medium);
  }

  /* White logo invisible on white bg — make it black */
  .nav.scrolled .nav-logo img {
    filter: brightness(0);
  }

  /* ============================================================
     DESKTOP NAV LINKS
     ============================================================ */
  .nav-links {
    display: flex;
    align-items: center;
    gap: 4px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-link {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 8px 14px;
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-white);
    background: none;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    transition: color var(--transition-medium);
    white-space: nowrap;
  }

  /* Underline grows from center */
  .nav-link:not(.nav-link-cta)::after {
    content: '';
    position: absolute;
    bottom: 4px;
    left: 50%;
    transform: translateX(-50%) scaleX(0);
    transform-origin: center;
    width: calc(100% - 28px);
    height: 2px;
    background: currentColor;
    border-radius: 1px;
    transition: transform var(--transition-fast);
  }

  .nav-link:not(.nav-link-cta):hover::after,
  .nav-link:not(.nav-link-cta):focus-visible::after {
    transform: translateX(-50%) scaleX(1);
  }

  /* Color flip on scrolled state */
  .nav.scrolled .nav-link:not(.nav-link-cta) {
    color: var(--color-black);
  }

  /* ============================================================
     CTA BUTTON
     ============================================================ */
  .nav-link-cta {
    background: var(--color-primary);
    color: var(--color-white) !important;
    padding: 10px 20px;
    border-radius: 8px;
    box-shadow: 0 4px 14px rgba(0, 133, 154, 0.35);
    transition:
      background var(--transition-fast),
      box-shadow var(--transition-fast),
      transform var(--transition-fast);
  }

  .nav-link-cta:hover {
    background: var(--color-primary-dark);
    box-shadow: 0 6px 20px rgba(0, 133, 154, 0.5);
    transform: translateY(-1px);
  }

  .nav-link-cta:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 3px;
  }

  /* ============================================================
     DROPDOWN TRIGGER (chevron)
     ============================================================ */
  .nav-item-dropdown {
    list-style: none;
  }

  .dropdown-chevron {
    transition: transform var(--transition-fast);
    flex-shrink: 0;
  }

  .nav-item-dropdown.open .dropdown-chevron {
    transform: rotate(180deg);
  }

  /* ============================================================
     MEGA MENU — full-width overlay panel
     ============================================================ */
  .mega-menu {
    position: fixed;
    top: var(--nav-height);
    left: 0;
    right: 0;
    width: 100vw;
    z-index: 999;
    background: white;
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.1);
    border-top: 1px solid rgba(0, 0, 0, 0.05);

    /* Hidden by default — slide-down animation */
    max-height: 0;
    overflow: hidden;
    opacity: 0;
    pointer-events: none;
    transition:
      max-height 0.35s ease,
      opacity 0.25s ease;
  }

  /* Visible state toggled via JS (.open class on nav-item-dropdown AND mega-menu) */
  .mega-menu.open {
    max-height: 400px;
    opacity: 1;
    pointer-events: auto;
  }

  .mega-menu-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 32px 24px;
  }

  /* 5-column grid */
  .mega-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 12px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  /* Stagger animation for each item — instant close, staggered open */
  .mega-item {
    opacity: 0;
    transform: translateY(6px);
    /* No delay on close — items disappear instantly */
    transition:
      opacity 0s ease,
      transform 0s ease;
  }

  .mega-menu.open .mega-item {
    opacity: 1;
    transform: translateY(0);
    /* Stagger delay only applies when opening */
    transition:
      opacity 0.22s ease calc(var(--i) * 0.05s + 0.1s),
      transform 0.22s ease calc(var(--i) * 0.05s + 0.1s);
  }

  /* Card */
  .mega-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 22px 16px 20px;
    border-radius: 12px;
    text-decoration: none;
    border: 2px solid transparent;
    transition:
      border-color 0.18s ease,
      transform 0.18s ease,
      background 0.18s ease;
  }

  .mega-card:hover,
  .mega-card:focus-visible {
    border-color: #00859a;
    transform: translateY(-2px);
    background: rgba(0, 133, 154, 0.02);
  }

  .mega-card:focus-visible {
    outline: 2px solid #00859a;
    outline-offset: 2px;
  }

  /* Icon circle */
  .mega-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: rgba(0, 133, 154, 0.08);
    margin-bottom: 14px;
    flex-shrink: 0;
    transition: background 0.18s ease;
  }

  .mega-card:hover .mega-icon,
  .mega-card:focus-visible .mega-icon {
    background: rgba(0, 133, 154, 0.16);
  }

  /* Title */
  .mega-title {
    display: block;
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-black);
    line-height: 1.3;
    margin-bottom: 6px;
    transition: color 0.18s ease;
  }

  .mega-card:hover .mega-title,
  .mega-card:focus-visible .mega-title {
    color: #00859a;
  }

  /* Description */
  .mega-desc {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    font-size: 0.82rem;
    font-weight: 400;
    color: #888;
    line-height: 1.45;
  }

  /* ============================================================
     HAMBURGER (hidden on desktop)
     ============================================================ */
  .hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 5px;
    width: 44px;
    height: 44px;
    padding: 8px;
    border-radius: 8px;
    background: none;
    border: none;
    cursor: pointer;
    transition: background var(--transition-fast);
  }

  .hamburger:hover {
    background: rgba(255, 255, 255, 0.15);
  }

  .nav.scrolled .hamburger:hover {
    background: var(--color-gray-50);
  }

  .hamburger-line {
    display: block;
    width: 22px;
    height: 2px;
    border-radius: 2px;
    background: var(--color-white);
    transition:
      transform var(--transition-fast),
      opacity var(--transition-fast),
      background var(--transition-medium);
  }

  .nav.scrolled .hamburger-line {
    background: var(--color-black);
  }

  /* Animate to X when open */
  .hamburger[aria-expanded="true"] .hamburger-line:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }

  .hamburger[aria-expanded="true"] .hamburger-line:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }

  .hamburger[aria-expanded="true"] .hamburger-line:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* ============================================================
     MOBILE OVERLAY
     ============================================================ */
  .mobile-overlay {
    position: fixed;
    inset: 0;
    z-index: 1001;
    background: rgba(0, 0, 0, 0.45);
    opacity: 0;
    pointer-events: none;
    transition: opacity var(--transition-medium);
  }

  .mobile-overlay.active {
    opacity: 1;
    pointer-events: auto;
  }

  /* ============================================================
     MOBILE SLIDE-IN PANEL
     ============================================================ */
  .mobile-menu {
    position: fixed;
    top: 0;
    right: 0;
    bottom: 0;
    z-index: 1002;
    width: min(320px, 88vw);
    background: var(--color-white);
    box-shadow: -8px 0 40px rgba(0, 0, 0, 0.15);
    display: flex;
    flex-direction: column;
    transform: translateX(100%);
    transition: transform var(--transition-medium);
    overflow-y: auto;
    overscroll-behavior: contain;
  }

  .mobile-menu.open {
    transform: translateX(0);
  }

  .mobile-menu-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px 20px 16px;
    border-bottom: 1px solid var(--color-gray-100);
    flex-shrink: 0;
  }

  .mobile-logo img {
    height: 34px;
    width: auto;
    filter: brightness(0);
  }

  .mobile-close {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 8px;
    color: var(--color-black);
    background: none;
    border: none;
    cursor: pointer;
    transition: background var(--transition-fast);
  }

  .mobile-close:hover {
    background: var(--color-gray-50);
  }

  /* ============================================================
     MOBILE NAV LIST
     ============================================================ */
  .mobile-nav-list {
    list-style: none;
    padding: 12px 12px 24px;
    margin: 0;
    flex: 1;
  }

  .mobile-nav-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: 13px 14px;
    border-radius: 8px;
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-black);
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
    transition: background var(--transition-fast), color var(--transition-fast);
  }

  .mobile-nav-link:hover,
  .mobile-nav-link:focus-visible {
    background: var(--color-gray-50);
    color: var(--color-primary);
  }

  .mobile-nav-cta {
    margin-top: 8px;
    background: var(--color-primary) !important;
    color: var(--color-white) !important;
    border-radius: 8px;
    justify-content: center;
    box-shadow: 0 4px 14px rgba(0, 133, 154, 0.3);
  }

  .mobile-nav-cta:hover {
    background: var(--color-primary-dark) !important;
    color: var(--color-white) !important;
  }

  /* Mobile accordion submenu */
  .mobile-item-accordion {
    list-style: none;
  }

  .accordion-chevron {
    transition: transform var(--transition-fast);
    flex-shrink: 0;
  }

  .mobile-accordion-btn[aria-expanded="true"] .accordion-chevron {
    transform: rotate(180deg);
  }

  .mobile-submenu {
    list-style: none;
    padding: 4px 0 4px 16px;
    margin: 0;
  }

  .mobile-sub-link {
    display: block;
    padding: 10px 14px;
    border-radius: 6px;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-gray-400);
    transition: background var(--transition-fast), color var(--transition-fast);
  }

  .mobile-sub-link:hover,
  .mobile-sub-link:focus-visible {
    background: var(--color-gray-50);
    color: var(--color-primary);
  }

  /* Left accent border for submenu */
  .mobile-submenu {
    border-left: 2px solid var(--color-gray-100);
    margin-left: 14px;
  }

  /* ============================================================
     RESPONSIVE — show hamburger, hide desktop links + mega menu
     ============================================================ */
  @media (max-width: 1024px) {
    .nav-links {
      display: none;
    }

    .hamburger {
      display: flex;
    }

    /* Mega menu never shows on mobile — mobile accordion handles it */
    .mega-menu {
      display: none !important;
    }
  }
</style>

<script>
  // ============================================================
  // SCROLL BEHAVIOR
  // ============================================================
  const nav = document.getElementById('main-nav') as HTMLElement;

  function updateNavScroll() {
    if (window.scrollY > 50) {
      nav.classList.add('scrolled');
    } else {
      nav.classList.remove('scrolled');
    }
  }

  // Initial check (in case page loads already scrolled)
  updateNavScroll();
  window.addEventListener('scroll', updateNavScroll, { passive: true });

  // ============================================================
  // DESKTOP MEGA MENU
  // ============================================================
  const dienstenBtn  = document.getElementById('diensten-btn')  as HTMLButtonElement;
  const dienstenMenu = document.getElementById('diensten-menu') as HTMLElement;
  const dienstenItem = dienstenBtn?.closest('.nav-item-dropdown') as HTMLElement;

  const isMobile = () => window.innerWidth <= 1024;

  function openMega() {
    if (isMobile()) return;
    dienstenItem.classList.add('open');
    dienstenMenu.classList.add('open');
    dienstenMenu.setAttribute('aria-hidden', 'false');
    dienstenBtn.setAttribute('aria-expanded', 'true');
    // Ensure nav has solid background while dropdown is open
    nav.classList.add('scrolled');
  }

  function closeMega() {
    dienstenItem.classList.remove('open');
    dienstenMenu.classList.remove('open');
    dienstenMenu.setAttribute('aria-hidden', 'true');
    dienstenBtn.setAttribute('aria-expanded', 'false');
    // Only remove solid background if user hasn't scrolled past 50px
    if (window.scrollY <= 50) {
      nav.classList.remove('scrolled');
    }
  }

  if (dienstenBtn && dienstenItem && dienstenMenu) {
    // Open on hover over the trigger item
    dienstenItem.addEventListener('mouseenter', openMega);
    dienstenItem.addEventListener('mouseleave', () => {
      // Give a brief moment so cursor can travel into the mega menu
      setTimeout(() => {
        if (!dienstenMenu.matches(':hover')) closeMega();
      }, 80);
    });

    // Keep open while hovering the mega menu itself
    dienstenMenu.addEventListener('mouseenter', openMega);
    dienstenMenu.addEventListener('mouseleave', closeMega);

    // Keyboard: Enter/Space toggles
    dienstenBtn.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        dienstenItem.classList.contains('open') ? closeMega() : openMega();
      }
    });

    // Keyboard: Escape closes
    dienstenItem.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') { closeMega(); dienstenBtn.focus(); }
    });
    dienstenMenu.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') { closeMega(); dienstenBtn.focus(); }
    });

    // Close when clicking outside
    document.addEventListener('click', (e) => {
      if (
        !dienstenItem.contains(e.target as Node) &&
        !dienstenMenu.contains(e.target as Node)
      ) {
        closeMega();
      }
    });
  }

  // ============================================================
  // MOBILE MENU
  // ============================================================
  const hamburger      = document.getElementById('hamburger-btn')   as HTMLButtonElement;
  const mobileMenu     = document.getElementById('mobile-menu')     as HTMLElement;
  const mobileOverlay  = document.getElementById('mobile-overlay')  as HTMLElement;
  const mobileCloseBtn = document.getElementById('mobile-close-btn') as HTMLButtonElement;

  function openMobileMenu() {
    mobileMenu.classList.add('open');
    mobileMenu.setAttribute('aria-hidden', 'false');
    mobileOverlay.classList.add('active');
    mobileOverlay.setAttribute('aria-hidden', 'false');
    hamburger.setAttribute('aria-expanded', 'true');
    hamburger.setAttribute('aria-label', 'Menu sluiten');
    document.body.style.overflow = 'hidden';
    mobileCloseBtn.focus();
  }

  function closeMobileMenu() {
    mobileMenu.classList.remove('open');
    mobileMenu.setAttribute('aria-hidden', 'true');
    mobileOverlay.classList.remove('active');
    mobileOverlay.setAttribute('aria-hidden', 'true');
    hamburger.setAttribute('aria-expanded', 'false');
    hamburger.setAttribute('aria-label', 'Menu openen');
    document.body.style.overflow = '';
    hamburger.focus();
  }

  hamburger?.addEventListener('click', () => {
    const isOpen = mobileMenu.classList.contains('open');
    isOpen ? closeMobileMenu() : openMobileMenu();
  });

  mobileCloseBtn?.addEventListener('click', closeMobileMenu);
  mobileOverlay?.addEventListener('click', closeMobileMenu);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && mobileMenu.classList.contains('open')) {
      closeMobileMenu();
    }
  });

  mobileMenu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', closeMobileMenu);
  });

  // ============================================================
  // MOBILE DIENSTEN ACCORDION
  // ============================================================
  const mobileDienstenBtn  = document.getElementById('mobile-diensten-btn')  as HTMLButtonElement;
  const mobileDienstenList = document.getElementById('mobile-diensten-list') as HTMLElement;

  mobileDienstenBtn?.addEventListener('click', () => {
    const isExpanded = mobileDienstenBtn.getAttribute('aria-expanded') === 'true';

    if (isExpanded) {
      mobileDienstenBtn.setAttribute('aria-expanded', 'false');
      mobileDienstenList.hidden = true;
    } else {
      mobileDienstenBtn.setAttribute('aria-expanded', 'true');
      mobileDienstenList.hidden = false;
    }
  });
</script>
