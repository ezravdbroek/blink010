---
// Navigation.astro — Sticky transparent navbar with scroll transition
import type { HTMLString } from 'astro/actions';

interface Props {
  lang?: 'nl' | 'en';
}

const { lang = 'nl' } = Astro.props;

const t = {
  nav: {
    home: lang === 'en' ? 'Home' : 'Home',
    services: lang === 'en' ? 'Services' : 'Diensten',
    about: lang === 'en' ? 'About Us' : 'Over Ons',
    contact: lang === 'en' ? 'Contact' : 'Contact',
    quote: lang === 'en' ? 'Get a Quote' : 'Offerte Aanvragen',
  },
  aria: {
    nav: lang === 'en' ? 'Main navigation' : 'Hoofdnavigatie',
    menuOpen: lang === 'en' ? 'Open menu' : 'Menu openen',
    menuClose: lang === 'en' ? 'Close menu' : 'Menu sluiten',
    back: lang === 'en' ? 'Back to main menu' : 'Terug naar hoofdmenu',
    mobileNav: lang === 'en' ? 'Mobile navigation' : 'Mobiele navigatie',
    servicesNav: lang === 'en' ? 'Services navigation' : 'Diensten navigatie',
    logo: lang === 'en' ? 'Blink Schoonmaak 010 — back to home' : 'Blink Schoonmaak 010 — terug naar home',
  },
  logoLabel: lang === 'en' ? 'Blink Schoonmaak 010 — home' : 'Blink Schoonmaak 010 — home',
};

const p = (path: string) => lang === 'en' ? '/en' + path : path;
---

<nav class="nav" id="main-nav" aria-label={t.aria.nav}>
  <div class="nav-inner">

    <!-- Logo -->
    <a href={lang === 'en' ? '/en/' : '/'} class="nav-logo" aria-label={t.aria.logo}>
      <img src="/logo.png" alt="Blink Schoonmaak 010" width="140" height="40" />
    </a>

    <!-- Desktop menu -->
    <ul class="nav-links" role="list">
      <li>
        <a href={lang === 'en' ? '/en/' : '/'} class="nav-link">{t.nav.home}</a>
      </li>

      <!-- Diensten mega menu trigger -->
      <li class="nav-item-dropdown">
        <button
          class="nav-link nav-link-dropdown"
          aria-haspopup="true"
          aria-expanded="false"
          id="diensten-btn"
        >
          {t.nav.services}
          <svg class="dropdown-chevron" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path d="M2 5l5 5 5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </li>

      <li>
        <a href={lang === 'en' ? '/en/over-ons' : '/over-ons'} class="nav-link">{t.nav.about}</a>
      </li>
      <li>
        <a href={lang === 'en' ? '/en/contact' : '/contact'} class="nav-link">{t.nav.contact}</a>
      </li>
      <li>
        <a href={lang === 'en' ? '/en/offerte-aanvragen' : '/offerte-aanvragen'} class="nav-link nav-link-cta">{t.nav.quote}</a>
      </li>

      <!-- Language switcher -->
      <li class="nav-lang-switcher">
        {lang === 'en' ? (
          <a href={Astro.url.pathname.replace('/en/', '/')} class="nav-lang-link" aria-label="Nederlands">
            <svg class="nav-flag" width="22" height="16" viewBox="0 0 30 20" aria-hidden="true">
              <rect width="30" height="6.67" fill="#AE1C28"/>
              <rect y="6.67" width="30" height="6.67" fill="#FFF"/>
              <rect y="13.33" width="30" height="6.67" fill="#21468B"/>
            </svg>
            <span>NL</span>
          </a>
        ) : (
          <a href={'/en' + Astro.url.pathname} class="nav-lang-link" aria-label="English">
            <svg class="nav-flag" width="22" height="16" viewBox="0 0 30 20" aria-hidden="true">
              <rect width="30" height="20" fill="#012169"/>
              <path d="M0 0l30 20m0-20L0 20" stroke="#FFF" stroke-width="3" fill="none"/>
              <path d="M0 0l30 20m0-20L0 20" stroke="#C8102E" stroke-width="1.5" fill="none"/>
              <path d="M0 10h30M15 0v20" stroke="#FFF" stroke-width="5" fill="none"/>
              <path d="M0 10h30M15 0v20" stroke="#C8102E" stroke-width="2.5" fill="none"/>
            </svg>
            <span>EN</span>
          </a>
        )}
      </li>
    </ul>

    <!-- Hamburger button (mobile) -->
    <button
      class="hamburger"
      id="hamburger-btn"
      aria-label={t.aria.menuOpen}
      aria-expanded="false"
      aria-controls="mobile-menu"
      data-open-label={t.aria.menuOpen}
      data-close-label={t.aria.menuClose}
    >
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
    </button>
  </div>
</nav>

<!-- Mega menu — full-width, positioned below the nav bar -->
<div class="mega-menu" id="diensten-menu" role="region" aria-labelledby="diensten-btn" aria-hidden="true">
  <div class="mega-menu-inner">
    <ul class="mega-grid" role="list">

      <li class="mega-item" style="--i:0">
        <a href={p('/kantoren-schoonmaak')} class="mega-card">
          <span class="mega-icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#00859a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/><path d="M7 6h.01"/><path d="M12 6h.01"/><path d="M17 6h.01"/>
            </svg>
          </span>
          <span class="mega-title">{lang === 'en' ? 'Office Cleaning' : 'Kantoren Schoonmaak'}</span>
          <span class="mega-desc">{lang === 'en' ? 'Professional office cleaning' : 'Professionele kantoorschoonmaak'}</span>
        </a>
      </li>

      <li class="mega-item" style="--i:1">
        <a href={p('/particuliere-schoonmaak')} class="mega-card">
          <span class="mega-icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#00859a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>
            </svg>
          </span>
          <span class="mega-title">{lang === 'en' ? 'Home Cleaning' : 'Particuliere Schoonmaak'}</span>
          <span class="mega-desc">{lang === 'en' ? 'Tailored home cleaning' : 'Huishoudelijke schoonmaak op maat'}</span>
        </a>
      </li>

      <li class="mega-item" style="--i:2">
        <a href={p('/restaurant-schoonmaak')} class="mega-card">
          <span class="mega-icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#00859a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 2v7c0 1.1.9 2 2 2h4a2 2 0 002-2V2"/><path d="M7 2v20"/><path d="M21 15V2a5 5 0 00-5 5v6c0 1.1.9 2 2 2h3zm0 0v7"/>
            </svg>
          </span>
          <span class="mega-title">{lang === 'en' ? 'Restaurant Cleaning' : 'Restaurant Schoonmaak'}</span>
          <span class="mega-desc">{lang === 'en' ? 'Hygienic hospitality cleaning' : 'Hygiënische horeca reiniging'}</span>
        </a>
      </li>

      <li class="mega-item" style="--i:3">
        <a href={p('/schoonmaak-recreatiewoning')} class="mega-card">
          <span class="mega-icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#00859a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><circle cx="12" cy="13" r="2"/><path d="M12 15v4"/>
            </svg>
          </span>
          <span class="mega-title">{lang === 'en' ? 'Holiday Home Cleaning' : 'Recreatiewoning Schoonmaak'}</span>
          <span class="mega-desc">{lang === 'en' ? 'Guest-ready holiday homes' : 'Vakantiewoning altijd gastklaar'}</span>
        </a>
      </li>

      <li class="mega-item" style="--i:4">
        <a href={p('/opleveringsschoonmaak')} class="mega-card">
          <span class="mega-icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#00859a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2l1.5 4.5L18 8l-4.5 1.5L12 14l-1.5-4.5L6 8l4.5-1.5z"/><path d="M5 16l1 3 3-1"/><path d="M19 16l-1 3-3-1"/>
            </svg>
          </span>
          <span class="mega-title">{lang === 'en' ? 'End of Tenancy' : 'Opleveringsschoonmaak'}</span>
          <span class="mega-desc">{lang === 'en' ? 'Thorough end-of-tenancy clean' : 'Grondige opleveringsreiniging'}</span>
        </a>
      </li>

      <li class="mega-item" style="--i:5">
        <a href={p('/housekeeping-airbnbs-hotels')} class="mega-card">
          <span class="mega-icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#00859a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><circle cx="12" cy="10" r="3"/><path d="M9 21v-4a3 3 0 016 0v4"/>
            </svg>
          </span>
          <span class="mega-title">Housekeeping</span>
          <span class="mega-desc">{lang === 'en' ? 'Airbnb, hotels & holiday homes' : 'Airbnb\'s, hotels & vakantiewoningen'}</span>
        </a>
      </li>

      <li class="mega-item" style="--i:6">
        <a href={p('/glasbewassing')} class="mega-card">
          <span class="mega-icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#00859a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="3" width="20" height="18" rx="2"/><path d="M8 7v10"/><path d="M16 7v10"/><path d="M2 12h20"/>
            </svg>
          </span>
          <span class="mega-title">{lang === 'en' ? 'Window Cleaning' : 'Glasbewassing'}</span>
          <span class="mega-desc">{lang === 'en' ? 'Streak-free window cleaning' : 'Streeploos schone ramen'}</span>
        </a>
      </li>

    </ul>
  </div>
</div>

<!-- Mobile fullscreen menu -->
<div
  class="mobile-menu"
  id="mobile-menu"
  role="dialog"
  aria-modal="true"
  aria-label={lang === 'en' ? 'Mobile menu' : 'Mobiel menu'}
  aria-hidden="true"
>
  <!-- ── Panel 1: Main menu ── -->
  <div class="mobile-panel" id="mobile-panel-main">
    <div class="mobile-menu-header">
      <a href={lang === 'en' ? '/en/' : '/'} class="mobile-logo" aria-label={t.logoLabel}>
        <img src="/logo.png" alt="Blink Schoonmaak 010" width="120" height="34" />
      </a>
      <button
        class="mobile-close"
        id="mobile-close-btn"
        aria-label={t.aria.menuClose}
      >
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
          <line x1="18" y1="6" x2="6" y2="18"/>
          <line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>

    <nav aria-label={t.aria.mobileNav}>
      <ul class="mobile-nav-list" role="list">
        <li>
          <a href={lang === 'en' ? '/en/' : '/'} class="mobile-nav-link">{t.nav.home}</a>
        </li>

        <!-- Diensten — slides to panel 2 -->
        <li>
          <button
            class="mobile-nav-link mobile-diensten-trigger"
            id="mobile-diensten-trigger"
            aria-haspopup="true"
          >
            {t.nav.services}
            <svg class="mobile-arrow-right" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M9 6l6 6-6 6"/>
            </svg>
          </button>
        </li>

        <li>
          <a href={lang === 'en' ? '/en/over-ons' : '/over-ons'} class="mobile-nav-link">{t.nav.about}</a>
        </li>
        <li>
          <a href={lang === 'en' ? '/en/contact' : '/contact'} class="mobile-nav-link">{t.nav.contact}</a>
        </li>
        <li>
          <a href={lang === 'en' ? '/en/offerte-aanvragen' : '/offerte-aanvragen'} class="mobile-nav-link mobile-nav-cta">{t.nav.quote}</a>
        </li>

        <!-- Mobile language switcher -->
        <li class="mobile-lang-item">
          <div class="mobile-lang-switcher">
            {lang === 'en' ? (
              <a href={Astro.url.pathname.replace('/en/', '/')} class="mobile-lang-link active" aria-label="Nederlands">
                <svg class="nav-flag" width="22" height="16" viewBox="0 0 30 20" aria-hidden="true">
                  <rect width="30" height="6.67" fill="#AE1C28"/>
                  <rect y="6.67" width="30" height="6.67" fill="#FFF"/>
                  <rect y="13.33" width="30" height="6.67" fill="#21468B"/>
                </svg>
                NL
              </a>
            ) : (
              <a href="/en" class="mobile-lang-link" aria-label="English">
                <svg class="nav-flag" width="22" height="16" viewBox="0 0 30 20" aria-hidden="true">
                  <rect width="30" height="20" fill="#012169"/>
                  <path d="M0 0l30 20m0-20L0 20" stroke="#FFF" stroke-width="3" fill="none"/>
                  <path d="M0 0l30 20m0-20L0 20" stroke="#C8102E" stroke-width="1.5" fill="none"/>
                  <path d="M0 10h30M15 0v20" stroke="#FFF" stroke-width="5" fill="none"/>
                  <path d="M0 10h30M15 0v20" stroke="#C8102E" stroke-width="2.5" fill="none"/>
                </svg>
                EN
              </a>
            )}
            <span class="mobile-lang-sep">|</span>
            {lang === 'en' ? (
              <span class="mobile-lang-link active">EN</span>
            ) : (
              <span class="mobile-lang-link active">NL</span>
            )}
          </div>
        </li>
      </ul>
    </nav>
  </div>

  <!-- ── Panel 2: Diensten sub-menu ── -->
  <div class="mobile-panel mobile-panel-diensten" id="mobile-panel-diensten">
    <div class="mobile-menu-header">
      <button
        class="mobile-back-btn"
        id="mobile-back-btn"
        aria-label={t.aria.back}
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M15 18l-6-6 6-6"/>
        </svg>
        {lang === 'en' ? 'Back' : 'Terug'}
      </button>
      <button
        class="mobile-close mobile-close-alt"
        id="mobile-close-btn-alt"
        aria-label="Menu sluiten"
      >
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
          <line x1="18" y1="6" x2="6" y2="18"/>
          <line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>

    <div class="diensten-panel-title">{lang === 'en' ? 'Services' : 'Diensten'}</div>

    <nav aria-label={t.aria.servicesNav}>
      <ul class="mobile-diensten-list" role="list">

        <li>
          <a href={p('/kantoren-schoonmaak')} class="mobile-diensten-link">
            <span class="mobile-diensten-icon" aria-hidden="true">
              <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#00859a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/><path d="M7 6h.01"/><path d="M12 6h.01"/><path d="M17 6h.01"/>
              </svg>
            </span>
            <span class="mobile-diensten-text">
              <span class="mobile-diensten-name">{lang === 'en' ? 'Office Cleaning' : 'Kantoren Schoonmaak'}</span>
              <span class="mobile-diensten-desc">{lang === 'en' ? 'Professional office cleaning' : 'Professionele kantoorschoonmaak'}</span>
            </span>
            <svg class="mobile-diensten-chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#ccc" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M9 6l6 6-6 6"/>
            </svg>
          </a>
        </li>

        <li>
          <a href={p('/particuliere-schoonmaak')} class="mobile-diensten-link">
            <span class="mobile-diensten-icon" aria-hidden="true">
              <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#00859a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>
              </svg>
            </span>
            <span class="mobile-diensten-text">
              <span class="mobile-diensten-name">{lang === 'en' ? 'Home Cleaning' : 'Particuliere Schoonmaak'}</span>
              <span class="mobile-diensten-desc">{lang === 'en' ? 'Tailored home cleaning' : 'Huishoudelijke schoonmaak op maat'}</span>
            </span>
            <svg class="mobile-diensten-chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#ccc" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M9 6l6 6-6 6"/>
            </svg>
          </a>
        </li>

        <li>
          <a href={p('/restaurant-schoonmaak')} class="mobile-diensten-link">
            <span class="mobile-diensten-icon" aria-hidden="true">
              <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#00859a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 2v7c0 1.1.9 2 2 2h4a2 2 0 002-2V2"/><path d="M7 2v20"/><path d="M21 15V2a5 5 0 00-5 5v6c0 1.1.9 2 2 2h3zm0 0v7"/>
              </svg>
            </span>
            <span class="mobile-diensten-text">
              <span class="mobile-diensten-name">{lang === 'en' ? 'Restaurant Cleaning' : 'Restaurant Schoonmaak'}</span>
              <span class="mobile-diensten-desc">{lang === 'en' ? 'Hygienic hospitality cleaning' : 'Hygiënische horeca reiniging'}</span>
            </span>
            <svg class="mobile-diensten-chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#ccc" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M9 6l6 6-6 6"/>
            </svg>
          </a>
        </li>

        <li>
          <a href={p('/schoonmaak-recreatiewoning')} class="mobile-diensten-link">
            <span class="mobile-diensten-icon" aria-hidden="true">
              <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#00859a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><circle cx="12" cy="13" r="2"/><path d="M12 15v4"/>
              </svg>
            </span>
            <span class="mobile-diensten-text">
              <span class="mobile-diensten-name">{lang === 'en' ? 'Holiday Home Cleaning' : 'Recreatiewoning Schoonmaak'}</span>
              <span class="mobile-diensten-desc">{lang === 'en' ? 'Guest-ready holiday homes' : 'Vakantiewoning altijd gastklaar'}</span>
            </span>
            <svg class="mobile-diensten-chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#ccc" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M9 6l6 6-6 6"/>
            </svg>
          </a>
        </li>

        <li>
          <a href={p('/opleveringsschoonmaak')} class="mobile-diensten-link">
            <span class="mobile-diensten-icon" aria-hidden="true">
              <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#00859a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 2l1.5 4.5L18 8l-4.5 1.5L12 14l-1.5-4.5L6 8l4.5-1.5z"/><path d="M5 16l1 3 3-1"/><path d="M19 16l-1 3-3-1"/>
              </svg>
            </span>
            <span class="mobile-diensten-text">
              <span class="mobile-diensten-name">{lang === 'en' ? 'End of Tenancy' : 'Opleveringsschoonmaak'}</span>
              <span class="mobile-diensten-desc">{lang === 'en' ? 'Thorough end-of-tenancy clean' : 'Grondige opleveringsreiniging'}</span>
            </span>
            <svg class="mobile-diensten-chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#ccc" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M9 6l6 6-6 6"/>
            </svg>
          </a>
        </li>

        <li>
          <a href={p('/housekeeping-airbnbs-hotels')} class="mobile-diensten-link">
            <span class="mobile-diensten-icon" aria-hidden="true">
              <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#00859a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><circle cx="12" cy="10" r="3"/><path d="M9 21v-4a3 3 0 016 0v4"/>
              </svg>
            </span>
            <span class="mobile-diensten-text">
              <span class="mobile-diensten-name">Housekeeping</span>
              <span class="mobile-diensten-desc">{lang === 'en' ? 'Airbnb, hotels & holiday homes' : 'Airbnb\'s, hotels & vakantiewoningen'}</span>
            </span>
            <svg class="mobile-diensten-chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#ccc" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M9 6l6 6-6 6"/>
            </svg>
          </a>
        </li>

        <li>
          <a href={p('/glasbewassing')} class="mobile-diensten-link">
            <span class="mobile-diensten-icon" aria-hidden="true">
              <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#00859a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="3" width="20" height="18" rx="2"/><path d="M8 7v10"/><path d="M16 7v10"/><path d="M2 12h20"/>
              </svg>
            </span>
            <span class="mobile-diensten-text">
              <span class="mobile-diensten-name">{lang === 'en' ? 'Window Cleaning' : 'Glasbewassing'}</span>
              <span class="mobile-diensten-desc">{lang === 'en' ? 'Streak-free window cleaning' : 'Streeploos schone ramen'}</span>
            </span>
