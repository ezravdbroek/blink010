---
import { Image } from 'astro:assets';

interface BreadcrumbItem {
  label: string;
  href: string;
}

interface Props {
  title: string;
  subtitle?: string;
  ctaText?: string;
  ctaHref?: string;
  image?: ImageMetadata;
  breadcrumbs?: BreadcrumbItem[];
}

const { title, subtitle, ctaText, ctaHref = '/offerte-aanvragen', image, breadcrumbs = [] } = Astro.props;
---

<section class="hero-banner">
  {image && (
    <div class="hero-banner-bg">
      <Image src={image} alt="" width={1920} height={1080} format="webp" quality={80} loading="eager" />
    </div>
  )}
  <div class="hero-banner-overlay"></div>
  <div class="hero-banner-content">
    {breadcrumbs.length > 0 && (
      <nav class="breadcrumb" aria-label="Breadcrumb">
        {breadcrumbs.map((crumb) => (
          <><a href={crumb.href}>{crumb.label}</a><span class="sep">›</span></>
        ))}
        <span class="current">{title}</span>
      </nav>
    )}
    <h1>{title}</h1>
    {subtitle && <p class="hero-subtitle">{subtitle}</p>}
    {ctaText && (
      <a href={ctaHref} class="hero-cta">
        {ctaText}
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    )}
  </div>
</section>

<style>
  .hero-banner {
    position: relative;
    height: 65vh;
    min-height: 480px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-primary);
    overflow: hidden;
  }

  .hero-banner-bg {
    position: absolute;
    inset: -10px;
    animation: kenBurnsBanner 20s ease-in-out infinite alternate;
  }

  .hero-banner-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @keyframes kenBurnsBanner {
    0% { transform: scale(1); }
    100% { transform: scale(1.03); }
  }

  .hero-banner-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
  }

  .hero-banner-content {
    position: relative;
    z-index: 2;
    text-align: center;
    padding: 0 24px;
    padding-top: var(--nav-height);
    max-width: 900px;
    color: var(--color-white);
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    font-size: 0.8rem;
    margin-bottom: 16px;
  }

  .breadcrumb a {
    color: rgba(255, 255, 255, 0.6);
    transition: color var(--transition-fast);
  }

  .breadcrumb a:hover {
    color: var(--color-white);
  }

  .breadcrumb .sep {
    color: rgba(255, 255, 255, 0.35);
  }

  .breadcrumb .current {
    color: rgba(255, 255, 255, 0.8);
  }

  h1 {
    color: var(--color-white);
    font-weight: var(--font-weight-extrabold);
    margin-bottom: 16px;
  }

  .hero-subtitle {
    color: rgba(255, 255, 255, 0.85);
    font-size: 1.1rem;
    line-height: 1.7;
    max-width: 720px;
    margin: 0 auto 28px;
  }

  .hero-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--color-white);
    color: var(--color-primary);
    padding: 14px 32px;
    border-radius: 10px;
    font-weight: var(--font-weight-bold);
    font-size: 1rem;
    text-decoration: none;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
    transition: transform var(--transition-fast), box-shadow var(--transition-fast);
  }

  .hero-cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 28px rgba(0, 0, 0, 0.25);
  }

  @media (max-width: 768px) {
    .hero-banner {
      height: auto;
      min-height: 0;
      padding: calc(var(--nav-height) + 32px) 0 40px;
    }

    .hero-banner-content {
      padding: 0 20px;
      padding-top: 0;
    }

    h1 {
      font-size: clamp(1.75rem, 8vw, 2.5rem);
    }

    .breadcrumb {
      font-size: 0.7rem;
      flex-wrap: wrap;
      justify-content: center;
      margin-bottom: 12px;
    }

    .hero-subtitle {
      font-size: 0.95rem;
    }

    .hero-cta {
      padding: 12px 24px;
      font-size: 0.9rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-banner-bg {
      animation: none;
    }
  }
</style>
